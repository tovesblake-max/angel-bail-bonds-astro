---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  structuredData?: object;
}

const { title, description, ogImage, ogType = 'website', canonicalURL, structuredData } = Astro.props;
const fullTitle = title + ' | Angel Bail Bonds';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    
    <!-- Canonical URL -->
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    {ogImage && <meta property="twitter:image" content={ogImage} />}
    
    <!-- Structured Data -->
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{fullTitle}</title>
  </head>
  <body class="bg-cream text-charcoal">
    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 bg-agate/95 backdrop-blur-lg border-b border-gold/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center space-x-2 group">
            <img 
              src="/images/logo.webp"
              alt="Angel Bail Bonds Logo"
              class="h-12 w-auto"
            />
            <span class="hidden sm:inline text-cream font-display font-bold text-lg">Angel Bail Bonds</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center space-x-8">
            <a href="/" class="text-cream hover:text-gold transition-colors">Home</a>
            <a href="/services" class="text-cream hover:text-gold transition-colors">Services</a>
            <a href="/how-bail-works" class="text-cream hover:text-gold transition-colors">How Bail Works</a>
            <a href="/about" class="text-cream hover:text-gold transition-colors">About</a>
            <a href="/blog" class="text-cream hover:text-gold transition-colors">Blog</a>
            <a href="/contact" class="text-cream hover:text-gold transition-colors">Contact</a>
          </div>

          <!-- CTA Button + Mobile Menu -->
          <div class="flex items-center space-x-4">
            <a 
              href="tel:+14056143000" 
              class="hidden sm:inline-block bg-gold hover:bg-gold/90 text-charcoal font-bold py-2 px-4 rounded transition-colors"
            >
              Call Now
            </a>
            
            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden text-cream hover:text-gold transition-colors" aria-label="Toggle menu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gold/20">
          <a href="/" class="block text-cream hover:text-gold py-2 transition-colors">Home</a>
          <a href="/services" class="block text-cream hover:text-gold py-2 transition-colors">Services</a>
          <a href="/how-bail-works" class="block text-cream hover:text-gold py-2 transition-colors">How Bail Works</a>
          <a href="/about" class="block text-cream hover:text-gold py-2 transition-colors">About</a>
          <a href="/blog" class="block text-cream hover:text-gold py-2 transition-colors">Blog</a>
          <a href="/contact" class="block text-cream hover:text-gold py-2 transition-colors">Contact</a>
          <a 
            href="tel:+14056143000" 
            class="block mt-4 bg-gold hover:bg-gold/90 text-charcoal font-bold py-2 px-4 rounded transition-colors text-center"
          >
            Call Now
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-charcoal text-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Brand -->
          <div>
            <h3 class="font-display text-xl mb-4 text-gold">Angel Bail Bonds</h3>
            <p class="text-sm text-cream/80 mb-4">
              15+ years of experience serving Central Oklahoma with integrity and compassion.
            </p>
            <div class="flex items-center space-x-2">
              <span class="text-gold">⭐</span>
              <span class="text-sm">5.0 Stars • 27+ Reviews</span>
            </div>
          </div>

          <!-- Service Areas -->
          <div>
            <h4 class="font-display text-lg mb-4 text-gold">Service Areas</h4>
            <ul class="text-sm space-y-2 text-cream/80">
              <li><a href="/payne-county-jail-bail-bonds" class="hover:text-gold transition-colors">Payne County</a></li>
              <li><a href="/pawnee-county-bail-bonds" class="hover:text-gold transition-colors">Pawnee County</a></li>
              <li><a href="/lincoln-county-bail-bonds" class="hover:text-gold transition-colors">Lincoln County</a></li>
              <li><a href="/kay-county-bail-bonds" class="hover:text-gold transition-colors">Kay County</a></li>
              <li><a href="/noble-county-bail-bonds" class="hover:text-gold transition-colors">Noble County</a></li>
            </ul>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="font-display text-lg mb-4 text-gold">Quick Links</h4>
            <ul class="text-sm space-y-2 text-cream/80">
              <li><a href="/services" class="hover:text-gold transition-colors">Services</a></li>
              <li><a href="/how-bail-works" class="hover:text-gold transition-colors">How Bail Works</a></li>
              <li><a href="/about" class="hover:text-gold transition-colors">About Us</a></li>
              <li><a href="/blog" class="hover:text-gold transition-colors">Blog</a></li>
              <li><a href="/contact" class="hover:text-gold transition-colors">Contact</a></li>
              <li><a href="/es/" class="hover:text-gold transition-colors">Español</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-display text-lg mb-4 text-gold">Contact</h4>
            <div class="text-sm space-y-3 text-cream/80">
              <div>
                <p class="text-gold">Phone</p>
                <a href="tel:+14056143000" class="hover:text-gold transition-colors">(405) 614-3000</a>
              </div>
              <div>
                <p class="text-gold">Email</p>
                <a href="mailto:bailbondangel@gmail.com" class="hover:text-gold transition-colors">bailbondangel@gmail.com</a>
              </div>
              <div>
                <p class="text-gold">Location</p>
                <p>Stillwater, Oklahoma</p>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-cream/20 pt-8 mt-8 text-center text-sm text-cream/60">
          <p>&copy; {new Date().getFullYear()} Angel Bail Bonds. All rights reserved. 24/7 Availability • Women-Owned Business</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });

        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
