      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Creek County Justice Center Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 110px;">Address</td><td style="padding: 10px 0; color: var(--slate-700);">9175 Ridgeview St, Sapulpa, OK 74066</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td><td style="padding: 10px 0; color: var(--slate-700);">(918) 227-6371</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Alt Phone</td><td style="padding: 10px 0; color: var(--slate-700);">(918) 224-4964</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Booking</td><td style="padding: 10px 0; color: var(--slate-700);">24 hours / 7 days a week</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td><td style="padding: 10px 0; color: var(--slate-700);">Mon–Fri 7:30 AM – 9:00 PM · Sat–Sun 7:30 AM – 2:30 PM</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">County Seat</td><td style="padding: 10px 0; color: var(--slate-700);">Sapulpa</td></tr>
          <tr style="border-bottom: 1px solid var(--slate-100);"><td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Population</td><td style="padding: 10px 0; color: var(--slate-700);">~72,930 (2020 Census)</td></tr>
