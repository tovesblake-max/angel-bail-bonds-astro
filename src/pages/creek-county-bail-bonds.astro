      <span style="background-color: var(--blue); color: white; padding: 0.5rem 1rem; border-radius: 1.5rem; font-size: 0.9rem; font-weight: 500;">Depew</span>
      <span style="background-color: var(--blue); color: white; padding: 0.5rem 1rem; border-radius: 1.5rem; font-size: 0.9rem; font-weight: 500;">Kiefer</span>
