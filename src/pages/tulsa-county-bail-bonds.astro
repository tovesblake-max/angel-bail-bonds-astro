  <section style="padding: var(--spacing-8, 3rem) var(--spacing-4, 1rem); background-color: white;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: var(--text-3xl, 1.875rem); font-weight: 700; margin-bottom: var(--spacing-6, 1.5rem); color: var(--color-primary, #1a365d);">
        How Bail Bonds Work in Tulsa County
      </h2>

      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--spacing-6, 1.5rem); margin-bottom: var(--spacing-8, 3rem);">
        <div style="background-color: var(--color-neutral-50, #f9fafb); padding: var(--spacing-6, 1.5rem); border-radius: var(--radius-lg, 0.5rem); border-top: 4px solid var(--color-accent, #d97706);">
