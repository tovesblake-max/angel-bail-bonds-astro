---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  url: 'https://stillwaterokbailbonds.com/payne-county-jail-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/payne-county-jail-bail-bonds#business',
  name: 'Angel Bail Bonds - Payne County Jail Specialist',
  description: 'Specialized bail bond services for Payne County Jail in Stillwater, Oklahoma.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Stillwater',
    addressRegion: 'OK',
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: 36.1156, longitude: -97.0584 },
  areaServed: 'Payne County, Oklahoma',
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Payne County Jail Bail Bonds', item: 'https://stillwaterokbailbonds.com/payne-county-jail-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Payne County Jail Bail Bonds"
  description="Expert bail bond services for Payne County Jail in Stillwater, Oklahoma. We specialize in fast releases and know Payne County procedures inside out."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Payne County Jail — Stillwater, OK</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Payne County Jail</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Stillwater, Oklahoma · Served 24/7 with local expertise</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Payne County Service</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">Location</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Stillwater, Oklahoma</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Jurisdiction</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Payne County (Stillwater area)</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Response Time</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Immediate (24/7 available)</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Bail Out -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Bail Someone Out in Payne County</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Arrest &amp; Booking</strong><br><span style="color: var(--slate-500);">Defendant taken to jail, 1-2 hours</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Initial Appearance</strong><br><span style="color: var(--slate-500);">Judge sets bail (24-72 hours)</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Call Angel Bail Bonds</strong><br><span style="color: var(--slate-500);">(405) 614-3000 · Any time</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Released</strong><br><span style="color: var(--slate-500);">30-60 min local processing</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How long does it take to get someone out of Payne County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">From the time bail is set to release, it typically takes 1-2 hours at Payne County Jail. We work directly with jail staff to minimize processing time. At Angel Bail Bonds, we often achieve releases in under 1 hour.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What does a bail bond cost in Payne County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Angel Bail Bonds offers competitive rates on bail bonds. The premium is non-refundable and allows you to get your loved one out without paying the full bail amount in cash. Call us to discuss pricing.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Do Payne County bail bonds expire?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">No. Once posted, the bond remains valid until the case is resolved or the bail conditions change. You remain responsible for ensuring the defendant follows all court orders.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Can bail be modified in Payne County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Yes. If bail seems excessive or harsh, an attorney can request a bail modification hearing. We can help coordinate this and discuss your options.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What if they fail to appear at Payne County Court?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">If the defendant fails to appear, the full bail amount becomes due immediately. The co-signer becomes liable for the entire amount, and a warrant is issued for the defendant's arrest. Additional charges may also be filed.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What makes Angel Bail Bonds different for Payne County bonds?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">We understand that bail can be a financial burden. Angel Bail Bonds offers competitive rates and works with you to find a solution that fits your situation. Call us at (405) 614-3000.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Need Payne County Bail Bond Help?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Local experts · 15+ years experience · Competitive rates</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
