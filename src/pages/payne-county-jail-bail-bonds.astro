---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Payne County Jail Specialist',
  description: 'Specialized bail bond services for Payne County Jail in Stillwater, Oklahoma.',
  image: '/images/logo.png',
  telephone: '(405) 614-3000',
  areaServed: 'Payne County, Oklahoma',
