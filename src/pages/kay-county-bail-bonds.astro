---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/kay-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Kay County',
      url: 'https://stillwaterokbailbonds.com/kay-county-bail-bonds',
      description: 'Professional bail bond services for Kay County, Oklahoma. 24/7 emergency bail bonds with 15+ years experience.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Kay County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 36.8670, longitude: -97.0531 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
    },
    {
      '@type': 'Service',
      name: 'Kay County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/kay-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Kay County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Kay County arrests and jail releases.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Kay County Bail Bonds', item: 'https://stillwaterokbailbonds.com/kay-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I get a bail bond in Kay County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Kay County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Kay County?',
          acceptedAnswer: { '@type': 'Answer', text: 'In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Kay County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Kay County Jail occur within 1-4 hours depending on jail processing.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Kay County Bail Bonds"
  description="24/7 bail bond services for Kay County, Oklahoma. Angel Bail Bonds offers fast, confidential bail bond processing. 15+ years experience, 4.9 stars. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Kay County, Oklahoma</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Kay County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Newkirk, Ponca City, Blackwell, Tonkawa, and surrounding areas · 24/7 service</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: County Info -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Kay County Overview</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">County Seat</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Newkirk</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Major Cities</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Ponca City, Blackwell, Tonkawa</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Service Area</td>
            <td style="padding: 10px 0; color: var(--slate-700);">North-central OK · Kansas border</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Get Bail Bond -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Get Bail in Kay County</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Contact jail</strong><br><span style="color: var(--slate-500);">Get inmate info & bail amount</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call Angel Bail Bonds</strong><br><span style="color: var(--slate-500);">(405) 614-3000 · 24/7</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay premium & sign</strong><br><span style="color: var(--slate-500);">Cash, cards accepted</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">1-4 hours processing time</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- ABOUT KAY COUNTY — unique local content -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.3rem; font-weight: 700; margin-bottom: 16px;">About Kay County, Oklahoma</h2>
      <div style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7;">
        <p style="margin-bottom: 14px;">Kay County is one of the largest counties in north-central Oklahoma, with a population of approximately 44,000 residents. The county seat is Newkirk, where the Kay County Courthouse is located at 201 S Main St. Established during the Cherokee Outlet Land Run of 1893, Kay County sits along the Oklahoma-Kansas border and covers roughly 920 square miles of rolling prairie and river bottom land along the Arkansas River.</p>
        <p style="margin-bottom: 14px;">Ponca City is the largest city in Kay County, with a population of around 25,000. Other communities we serve include Blackwell, Tonkawa (home to Northern Oklahoma College), Braman, Kaw City, and Nardin. Whether the arrest happens in Ponca City after a traffic stop on US-77, in Blackwell near I-35, or anywhere else in the county, Angel Bail Bonds can help.</p>
        <p style="margin-bottom: 14px;">All Kay County criminal cases are handled through the Kay County District Court in Newkirk. If someone you know has been arrested in Kay County, bail is typically set according to a bond schedule maintained by the Kay County court system. Misdemeanor bail amounts are generally lower, while felony charges require higher bonds that may need a judge's approval. Angel Bail Bonds has extensive experience navigating the Kay County court system and can walk you through what to expect for your specific situation.</p>
      </div>

      <h3 style="color: var(--navy); font-size: 1.1rem; font-weight: 700; margin-top: 28px; margin-bottom: 12px;">Driving to Kay County from Stillwater</h3>
      <p style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7; margin-bottom: 14px;">From Stillwater, Kay County is approximately 80-90 minutes north. The most direct route to the Kay County Detention Center in Newkirk is to take US-177 North through Perry and Red Rock, then continue north on US-77 into Newkirk. For arrests in Ponca City, take US-177 North to I-35 North, then exit onto US-77 North into Ponca City. However, you do not need to make the drive yourself. In many cases, Angel Bail Bonds can coordinate bond posting remotely, saving you time and allowing your loved one to be released sooner.</p>
    </div>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I get a bail bond in Kay County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Kay County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How much does a bail bond cost in Kay County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How long does it take to get released from Kay County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Kay County Jail occur within 1-4 hours depending on jail processing.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Does Angel Bail Bonds serve Ponca City and Blackwell?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Yes. We serve all of Kay County, including Ponca City, Blackwell, Tonkawa, Newkirk, Braman, Kaw City, and every other community within the county. We can often coordinate bond posting remotely so you do not have to drive to Newkirk yourself.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/kay-county-detention-center-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Kay County Detention Center →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Need a Kay County Bail Bond?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Women-owned · 15+ years · 4.9 stars · Competitive rates</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
