---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/washington-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Washington County',
      url: 'https://stillwaterokbailbonds.com/washington-county-bail-bonds',
      description: 'Professional 24/7 bail bond services for Washington County, Oklahoma. Serving the Washington County Correctional Facility in Bartlesville with fast releases and competitive rates.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: [
        { '@type': 'AdministrativeArea', name: 'Washington County, Oklahoma' },
        { '@type': 'City', name: 'Bartlesville, Oklahoma' },
        { '@type': 'City', name: 'Dewey, Oklahoma' },
        { '@type': 'City', name: 'Copan, Oklahoma' },
        { '@type': 'City', name: 'Ochelata, Oklahoma' },
        { '@type': 'City', name: 'Ramona, Oklahoma' },
        { '@type': 'City', name: 'Vera, Oklahoma' },
        { '@type': 'City', name: 'Wann, Oklahoma' },
        { '@type': 'City', name: 'Lenapah, Oklahoma' },
      ],
      geo: { '@type': 'GeoCoordinates', latitude: 36.7468, longitude: -95.9805 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      paymentAccepted: ['Cash', 'Visa', 'Mastercard', 'Zelle', 'Venmo'],
      priceRange: 'Competitive rates with financing available',
    },
    {
      '@type': 'Service',
      name: 'Washington County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/washington-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Washington County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Washington County arrests at the Washington County Correctional Facility in Bartlesville, Oklahoma.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Washington County Bail Bonds', item: 'https://stillwaterokbailbonds.com/washington-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I bail someone out of Washington County Jail in Bartlesville?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, day or night. We verify the charges and bail amount with the Washington County Correctional Facility at 611 SW Adams Blvd in Bartlesville (jail phone: 918-332-4011), handle all paperwork remotely by phone or e-sign, and post bail. Most releases take 1-2 hours after bond is posted. The facility has a capacity of approximately 60 inmates and processes around 2,469 bookings per year.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Washington County, Oklahoma?',
          acceptedAnswer: { '@type': 'Answer', text: 'Washington County bail bond costs depend on the bail amount set by the court. Typical bail amounts range from approximately $1,000 for a DUI, $500-$5,000 for misdemeanors, and $5,000-$100,000+ for felonies. Angel Bail Bonds charges a competitive premium — typically 10% of the total bail. We accept cash, Visa, Mastercard, Zelle, and Venmo, and offer financing for larger bonds. Call (405) 614-3000 for a free quote.' },
        },
        {
          '@type': 'Question',
          name: 'What are the visiting hours at Washington County Correctional Facility?',
          acceptedAnswer: { '@type': 'Answer', text: 'Washington County Correctional Facility visiting hours are Monday through Friday 7:30 AM to 9:00 PM, and Saturday and Sunday 7:30 AM to 2:30 PM. Visits last 30 minutes and must be scheduled by calling (918) 332-4000. The first visit per 30-day period is free, then $10 per visit. Visits are limited to one adult and one child per inmate. A valid photo ID is required for all visitors.' },
        },
        {
          '@type': 'Question',
          name: 'When are arraignments held in Washington County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Washington County arraignments and court dockets are held at the Washington County Courthouse, 420 S Johnstone Ave in Bartlesville. The Court Clerk is Jean Davis, reachable at (918) 337-2840. Office hours are Monday through Friday, 8:00 AM to 5:00 PM (filings accepted until 4:45 PM). Contact the court clerk for specific arraignment dates and docket schedules.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Washington County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'After Angel Bail Bonds posts your bail at the Washington County Correctional Facility, most defendants are released within 1-2 hours. Processing includes paperwork verification, property return, and outprocessing. Weekend and holiday releases may take slightly longer due to staffing levels among the facility\'s 74+ staff members. We stay in contact until your loved one walks out.' },
        },
        {
          '@type': 'Question',
          name: 'Can I bail someone out of Washington County Jail over the phone?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds handles the entire Washington County bail process remotely — by phone, email, or e-sign. You do not need to visit our office or the jail. We complete paperwork electronically, post bail at the Washington County Correctional Facility, and keep you updated until release. This is especially convenient since Bartlesville is approximately 95 miles from Stillwater.' },
        },
        {
          '@type': 'Question',
          name: 'How do I find an inmate in Washington County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'Search the Washington County Correctional Facility inmate roster online at washingtoncosheriff.com/inmate-search, updated hourly. You can also call the jail at (918) 332-4011 or the Sheriff\'s Office at (918) 337-2800. For custody status alerts, register with Oklahoma VINE at (877) 654-8463. Angel Bail Bonds can also look up inmates for you free of charge — call (405) 614-3000.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Washington County Bail Bonds — Bartlesville, OK | Angel Bail Bonds 24/7"
  description="24/7 bail bond services for Washington County Correctional Facility in Bartlesville, Oklahoma. Angel Bail Bonds offers competitive rates, fast releases (1-2 hours), and 15+ years experience. Sheriff Scott Owen facility, capacity ~60. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Washington County, Oklahoma · Bartlesville</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Washington County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Serving Bartlesville, Dewey, Copan, Ochelata, Ramona, Vera, Wann & surrounding areas · 24/7</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
        <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
        <span style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Competitive Rates · Financing Available</span>
      </div>
    </div>
  </section>

  <!-- GEO ANSWER CAPSULE — Primary citability block -->
  <section style="padding: 40px 1.5rem; background: white; border-bottom: 1px solid var(--slate-100);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">How Do I Bail Someone Out of Washington County Jail?</h2>
      <div style="background: var(--slate-50); border-left: 4px solid var(--blue); padding: 20px 24px; border-radius: 0 8px 8px 0; margin-bottom: 20px;">
        <p style="color: var(--slate-700); font-size: 0.95rem; line-height: 1.75;">
          <strong>To bail someone out of the Washington County Correctional Facility in Bartlesville, Oklahoma, call Angel Bail Bonds at (405) 614-3000. The jail is at 611 SW Adams Boulevard, Bartlesville, OK 74003, phone (918) 332-4011, under Sheriff Scott Owen. The facility holds approximately 60 inmates and processes about 2,469 bookings per year (an average of 9 per day).</strong> After booking and arraignment, bail amounts are set by the court. Angel Bail Bonds offers competitive rates, accepts cash, Visa, Mastercard, Zelle, and Venmo, and handles everything remotely by phone or e-sign. Once bond is posted, most defendants are released within 1-2 hours. Court proceedings are held at the Washington County Courthouse, 420 S Johnstone Ave, Bartlesville — Court Clerk Jean Davis can be reached at (918) 337-2840.
        </p>
      </div>
      <p style="color: var(--slate-400); font-size: 0.75rem;">Last updated: March 2026 · Verified with Washington County Sheriff's Office</p>
    </div>
  </section>

  <!-- BOND COST ANSWER CAPSULE -->
  <section style="padding: 40px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">How Much Does a Washington County Bail Bond Cost?</h2>
      <div style="background: var(--slate-50); border-left: 4px solid var(--green); padding: 20px 24px; border-radius: 0 8px 8px 0; margin-bottom: 20px;">
        <p style="color: var(--slate-700); font-size: 0.95rem; line-height: 1.75;">
          <strong>Washington County bail bond costs depend on the bail amount set by the court. Common bail amounts include approximately $1,000 for a DUI, $500–$5,000 for misdemeanors, and $5,000–$100,000+ for felonies. Angel Bail Bonds charges a competitive premium — typically 10% of the total bail amount — and accepts cash, Visa, Mastercard, Zelle, and Venmo. Financing is available for larger bonds.</strong> Oklahoma law allows judges to set bail amounts based on the severity of the charge, criminal history, and flight risk. Contact Angel Bail Bonds at (405) 614-3000 for a free, no-obligation quote on any Washington County bail amount.
        </p>
      </div>

      <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse; background: white; border: 1px solid var(--slate-200); border-radius: 8px; overflow: hidden; margin-top: 16px;">
        <tr style="background: var(--navy); color: white;">
          <td style="padding: 10px 16px; font-weight: 600;">Charge Type</td>
          <td style="padding: 10px 16px; font-weight: 600;">Typical Bail Range</td>
          <td style="padding: 10px 16px; font-weight: 600;">Estimated Bond Premium</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">DUI / DWI</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$1,000–$2,500</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$100–$250</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Misdemeanor</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$500–$5,000</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$50–$500</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Felony</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$5,000–$100,000+</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$500–$10,000+</td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; color: var(--slate-700);">Drug Possession</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$1,000–$25,000</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">$100–$2,500</td>
        </tr>
      </table>
      <p style="color: var(--slate-400); font-size: 0.75rem; margin-top: 8px;">* Bail amounts vary by judge and case specifics. Amounts shown are estimates based on typical Oklahoma court bond schedules.</p>
    </div>
  </section>

  <!-- FACILITY + STEPS — two-column -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Washington County Correctional Facility</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 120px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);">611 SW Adams Blvd, Bartlesville, OK 74003</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Jail Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+19183324011" style="color: var(--blue); text-decoration: none;">(918) 332-4011</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visit Scheduling</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+19183324000" style="color: var(--blue); text-decoration: none;">(918) 332-4000</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Sheriff</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Scott Owen · <a href="tel:+19183372800" style="color: var(--blue); text-decoration: none;">(918) 337-2800</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Capacity</td>
            <td style="padding: 10px 0; color: var(--slate-700);">~60 inmates · 74+ staff</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bookings</td>
            <td style="padding: 10px 0; color: var(--slate-700);">~2,469/year · avg 9/day · 133/month</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visiting Hours</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Mon–Fri 7:30 AM–9:00 PM<br>Sat–Sun 7:30 AM–2:30 PM</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visit Duration</td>
            <td style="padding: 10px 0; color: var(--slate-700);">30 minutes · Scheduled via (918) 332-4000</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visit Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Free first visit per 30-day period, $10 thereafter</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitors</td>
            <td style="padding: 10px 0; color: var(--slate-700);">1 adult + 1 child per visit · Valid photo ID required</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-200);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Release Time</td>
            <td style="padding: 10px 0; color: var(--slate-700);">1-2 hours after bond posted</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Inmate Roster</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Updated hourly at washingtoncosheriff.com</td>
          </tr>
        </table>
      </div>

      <!-- Right: Steps -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Post Bail in Washington County</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Call Angel Bail Bonds</strong><br><span style="color: var(--slate-500);">(405) 614-3000 · 24/7 · Holidays included</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">We verify with the jail</strong><br><span style="color: var(--slate-500);">Charges, bond amount, booking status at Washington County Correctional Facility — (918) 332-4011</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Sign paperwork remotely</strong><br><span style="color: var(--slate-500);">E-sign, phone, or email — no office visit needed</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">4</span>
            <div><strong style="color: var(--slate-800);">We post bail</strong><br><span style="color: var(--slate-500);">Bond posted directly with Washington County Jail</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release in 1-2 hours</strong><br><span style="color: var(--slate-500);">We stay in contact until they walk out</span></div>
          </li>
        </ol>

        <div style="margin-top: 24px; padding: 16px 20px; background: white; border: 1px solid var(--slate-200); border-radius: 8px;">
          <p style="color: var(--slate-700); font-size: 0.88rem; font-weight: 600; margin-bottom: 6px;">💡 Good to Know</p>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">Washington County's inmate roster is updated hourly at washingtoncosheriff.com. You can check booking status and charges online before calling. Angel Bail Bonds can also look up any inmate for you free of charge.</p>
        </div>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- COURT INFORMATION — GEO citability block -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">Washington County Courthouse & Court Schedule</h2>
      <div style="background: var(--slate-50); border-left: 4px solid var(--blue); padding: 20px 24px; border-radius: 0 8px 8px 0; margin-bottom: 20px;">
        <p style="color: var(--slate-700); font-size: 0.95rem; line-height: 1.75;">
          <strong>The Washington County Courthouse is located at 420 South Johnstone Avenue, Bartlesville, OK 74003. The Court Clerk is Jean Davis, reachable at (918) 337-2840. Office hours are Monday through Friday, 8:00 AM to 5:00 PM, with filings accepted until 4:45 PM.</strong> Contact the court clerk for information about arraignment schedules, docket dates, and how to request a court appearance. Washington County operates under Oklahoma's criminal justice system with regular docket sessions throughout the month. The District Court handles all criminal matters including felonies, misdemeanors, and traffic violations.
        </p>
      </div>

      <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse; background: white; border: 1px solid var(--slate-200); border-radius: 8px; overflow: hidden;">
        <tr style="background: var(--navy); color: white;">
          <td style="padding: 10px 16px; font-weight: 600;">Court Information</td>
          <td style="padding: 10px 16px; font-weight: 600;">Details</td>
          <td style="padding: 10px 16px; font-weight: 600;">Contact</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Courthouse Address</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">420 S Johnstone Ave, Bartlesville, OK 74003</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 337-2840</td>
