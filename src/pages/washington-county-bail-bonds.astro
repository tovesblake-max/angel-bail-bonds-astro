        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Court Clerk Hours</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Monday–Friday 8:00 AM–5:00 PM</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Filings close at 4:45 PM</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Sheriff's Office</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Sheriff Scott Owen</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 337-2800</td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; color: var(--slate-700);">Emergency Dispatch</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Emergency & non-emergency dispatch</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 338-4001</td>
        </tr>
      </table>
    </div>
  </section>

  <!-- VISITING HOURS — GEO citability block -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">What Are Washington County Jail Visiting Hours?</h2>
