---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/washington-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Washington County',
      url: 'https://stillwaterokbailbonds.com/washington-county-bail-bonds',
      description: 'Professional 24/7 bail bond services for Washington County, Oklahoma. Serving the Washington County Correctional Facility in Bartlesville with fast releases and competitive rates.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Washington County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 36.7468, longitude: -95.9805 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      paymentAccepted: ['Cash', 'Credit Card', 'Zelle', 'Venmo'],
    },
    {
      '@type': 'Service',
      name: 'Washington County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/washington-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Washington County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Washington County arrests at the Washington County Correctional Facility in Bartlesville, Oklahoma.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Washington County Bail Bonds', item: 'https://stillwaterokbailbonds.com/washington-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I bail someone out of Washington County Jail in Bartlesville?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, day or night. We will verify the charges and bail amount with the Washington County Correctional Facility at 611 SW Adams Blvd in Bartlesville, handle all paperwork remotely, and post bail. Most releases take 1-2 hours after bond is posted. The jail can be reached directly at (918) 332-4011.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Washington County, Oklahoma?',
          acceptedAnswer: { '@type': 'Answer', text: 'Angel Bail Bonds offers competitive rates on Washington County bail bonds. The exact premium depends on the bail amount set by the court. We accept cash, Visa, Mastercard, Zelle, and Venmo, and offer financing options for larger bonds. Call (405) 614-3000 for a free quote on your specific situation.' },
        },
        {
          '@type': 'Question',
          name: 'What are the visiting hours at Washington County Correctional Facility?',
          acceptedAnswer: { '@type': 'Answer', text: 'Washington County Correctional Facility visiting hours are Monday through Friday 7:30 AM to 9:00 PM, and Saturday and Sunday 7:30 AM to 2:30 PM. Inmates receive one free 15-minute visit within each 30-day period (first visit is free, then $10 per visit). Visits are limited to one adult and one child per inmate. Call (918) 332-4011 to verify current visiting policies.' },
        },
        {
          '@type': 'Question',
          name: 'When are arraignments held in Washington County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Washington County arraignments and court dockets are held at the Washington County Courthouse, 420 S Johnstone Ave in Bartlesville. Contact the Court Clerk at (918) 337-2870 for current arraignment schedules and to inquire about upcoming court dates. Regular business hours are Monday through Friday, 8:30 AM to 4:30 PM.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Washington County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'After Angel Bail Bonds posts your bail at the Washington County Correctional Facility, most defendants are released within 1-2 hours. Processing includes paperwork verification, property return, and outprocessing. Weekend and holiday releases may take slightly longer due to staffing. We stay in contact until your loved one walks out.' },
        },
        {
          '@type': 'Question',
          name: 'Can I bail someone out of Washington County Jail over the phone?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds handles the entire Washington County bail process remotely — by phone, email, or e-sign. You do not need to visit our office or the jail. We complete paperwork electronically, post bail at the Washington County Correctional Facility, and keep you updated until release.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Washington County Bail Bonds — Bartlesville, OK | Angel Bail Bonds 24/7"
  description="24/7 bail bond services for Washington County Correctional Facility in Bartlesville, Oklahoma. Angel Bail Bonds offers competitive rates, fast releases (1-2 hours), and 15+ years experience. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Washington County, Oklahoma · Bartlesville</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Washington County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Serving Bartlesville, Dewey, Copan, Ochelata, Ramona, Vera, Wann & surrounding areas · 24/7</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
        <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
        <span style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Competitive Rates · Financing Available</span>
      </div>
    </div>
  </section>

  <!-- GEO ANSWER CAPSULE — Primary citability block -->
  <section style="padding: 40px 1.5rem; background: white; border-bottom: 1px solid var(--slate-100);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">How Do I Bail Someone Out of Washington County Jail?</h2>
      <div style="background: var(--slate-50); border-left: 4px solid var(--blue); padding: 20px 24px; border-radius: 0 8px 8px 0; margin-bottom: 20px;">
        <p style="color: var(--slate-700); font-size: 0.95rem; line-height: 1.75;">
          <strong>To bail someone out of the Washington County Correctional Facility in Bartlesville, Oklahoma, call Angel Bail Bonds at (405) 614-3000.</strong> The jail is located at 611 SW Adams Boulevard, Bartlesville, OK 74003 and can be reached at (918) 332-4011. After booking, bail amounts are set by the court. Angel Bail Bonds offers competitive rates, accepts cash, credit cards, Zelle, and Venmo, and handles everything remotely by phone or e-sign. Once bond is posted, most defendants are released within 1-2 hours. Visiting hours at Washington County Jail are Monday–Friday 7:30 AM–9:00 PM and Saturday–Sunday 7:30 AM–2:30 PM. Court proceedings are held at the Washington County Courthouse, 420 S Johnstone Ave, Bartlesville.
        </p>
      </div>
      <p style="color: var(--slate-400); font-size: 0.75rem;">Last updated: March 2026 · Verified with Washington County Sheriff's Office</p>
    </div>
  </section>

  <!-- FACILITY + STEPS — two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Washington County Correctional Facility</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 110px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);">611 SW Adams Blvd, Bartlesville, OK 74003</td>
          </tr>
