    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- COURT INFORMATION — GEO citability block -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px;">Washington County Courthouse & Court Schedule</h2>
      <div style="background: white; border: 1px solid var(--slate-200); border-radius: 8px; padding: 20px 24px; margin-bottom: 20px;">
        <p style="color: var(--slate-700); font-size: 0.95rem; line-height: 1.75;">
          <strong>The Washington County Courthouse is located at 420 South Johnstone Avenue, Bartlesville, OK 74003.</strong> The Court Clerk's Office can be reached at (918) 337-2870 and is open Monday through Friday, 8:30 AM to 4:30 PM. Contact the court clerk for information about arraignment schedules, docket dates, and how to request a court appearance. Washington County operates under Oklahoma's criminal justice system with regular docket sessions throughout the month.
        </p>
      </div>

      <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse; background: white; border: 1px solid var(--slate-200); border-radius: 8px; overflow: hidden;">
        <tr style="background: var(--navy); color: white;">
          <td style="padding: 10px 16px; font-weight: 600;">Court Information</td>
          <td style="padding: 10px 16px; font-weight: 600;">Details</td>
          <td style="padding: 10px 16px; font-weight: 600;">Contact</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Courthouse Address</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">420 S Johnstone Ave, Bartlesville, OK 74003</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 337-2870</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Court Clerk Hours</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Monday–Friday 8:30 AM–4:30 PM</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Closed weekends & holidays</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--slate-100);">
          <td style="padding: 10px 16px; color: var(--slate-700);">Docket Scheduling</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Call court clerk for current schedules</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 337-2870</td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; color: var(--slate-700);">Jail Dispatch</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">Emergency & non-emergency dispatch</td>
          <td style="padding: 10px 16px; color: var(--slate-700);">(918) 338-4001</td>
