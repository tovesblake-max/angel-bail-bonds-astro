---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Stillwater City Jail',
  description: 'Fast bail bond services for Stillwater City Jail at 723 S Lewis St, Stillwater, OK. 24/7 availability with quick release times.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: { '@type': 'PostalAddress', streetAddress: '723 S Lewis St', addressLocality: 'Stillwater', addressRegion: 'OK', postalCode: '74074', addressCountry: 'US' },
  areaServed: { '@type': 'AdministrativeArea', name: 'Stillwater, Oklahoma' },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How long do inmates stay at Stillwater City Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Stillwater City Jail is a short-term holding facility. Inmates typically stay less than 72 hours before being released or transferred to Payne County Detention Center. This is why acting fast on bail is critical — call Angel Bail Bonds at (405) 614-3000 before a transfer adds delays.' } },
    { '@type': 'Question', name: 'How do I bail someone out of Stillwater City Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We need the inmate\'s name and charges. Since Stillwater City Jail is a short-term facility, we prioritize getting bonds posted quickly before any transfer to the county detention center.' } },
    { '@type': 'Question', name: 'What is Stillwater City Jail\'s phone number?', acceptedAnswer: { '@type': 'Answer', text: 'Stillwater City Jail can be reached at (405) 372-4171. They are located at 723 S Lewis Street, Stillwater, OK 74074.' } },
    { '@type': 'Question', name: 'What happens after arrest at Stillwater City Jail?', acceptedAnswer: { '@type': 'Answer', text: 'After arrest, the individual is booked (fingerprinted, photographed, and personal information collected). They may be released without bail, held until a court appearance, or have bail set. If bail is set, calling a bail bondsman immediately is the fastest way to get released.' } }
  ]
};

const howToData = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Bail Someone Out of Stillwater City Jail',
  description: 'Step-by-step guide to posting bail at Stillwater City Jail in Oklahoma.',
  step: [
    { '@type': 'HowToStep', name: 'Get inmate information', text: 'Call Stillwater City Jail at (405) 372-4171 to confirm the person is in custody and get their booking details.' },
    { '@type': 'HowToStep', name: 'Call Angel Bail Bonds', text: 'Call (405) 614-3000 any time 24/7. We will confirm the bail amount and walk you through the process.' },
    { '@type': 'HowToStep', name: 'Complete bond paperwork and pay 10% premium', text: 'Sign the bond agreement and pay the 10% premium. Cash, credit cards, and payment plans accepted.' },
    { '@type': 'HowToStep', name: 'Bond posted and inmate released', text: 'We post the bond and the jail processes the release. Act fast — Stillwater City Jail transfers inmates to county within 72 hours.' }
  ]
};
---

<BaseLayout
  title="Stillwater City Jail Bail Bonds | 24/7 Fast Release"
  description="Need bail bonds for Stillwater City Jail at 723 S Lewis St? Angel Bail Bonds posts bonds 24/7. This is a short-term facility — act fast before transfer to county. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />

  <section style="background: linear-gradient(135deg, #1a6b6a 0%, #145453 100%); min-height: 50vh;" class="flex items-center text-cream">
    <div class="max-w-7xl mx-auto px-4 py-20 w-full">
      <p class="section-label" style="color: var(--gold);">Stillwater City Jail</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mb-4">Bail Bonds for<br><span style="color: var(--gold);">Stillwater City Jail</span></h1>
      <p class="text-lg md:text-xl max-w-2xl mb-4 opacity-90">723 S Lewis Street, Stillwater, OK 74074</p>
      <div style="background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.4); border-radius: 8px; padding: 12px 16px; max-width: 600px; margin-bottom: 32px;">
        <p style="font-weight: 600; color: var(--gold);">⚠️ Short-Term Facility — Act Fast</p>
        <p style="opacity: 0.9; font-size: 0.95rem;">Stillwater City Jail holds inmates for less than 72 hours before transferring to Payne County Detention Center. Posting bail here avoids transfer delays.</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        (405) 614-3000
      </a>
    </div>
  </section>

  <section style="background: var(--cream); padding: 80px 0;">
    <div class="max-w-7xl mx-auto px-4">
      <p class="section-label">Facility Details</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--agate);">Stillwater City Jail Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="card reveal"><div class="icon-box">📍</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Address</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">723 S Lewis Street<br>Stillwater, OK 74074</p></div>
        <div class="card reveal reveal-delay-1"><div class="icon-box">📞</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Phone</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">(405) 372-4171</p></div>
        <div class="card reveal reveal-delay-2"><div class="icon-box">🏢</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Capacity</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">23-bed short-term holding facility</p></div>
        <div class="card reveal reveal-delay-3"><div class="icon-box">⏱️</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Hold Time</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">Typically under 72 hours before transfer to Payne County</p></div>
      </div>
    </div>
  </section>

  <section style="padding: 100px 0; background: white;">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Step-by-Step Guide</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--agate);">How to Bail Someone Out of Stillwater City Jail</h2>
      <p style="color: var(--charcoal); opacity: 0.8; margin-bottom: 48px; font-size: 1.1rem;">Time matters at Stillwater City Jail. Inmates are transferred to the county facility within 72 hours, which adds processing delays. Here's how to act fast.</p>
      <div style="display: flex; flex-direction: column; gap: 32px;">
        <div class="reveal" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">1</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Confirm They're at Stillwater City Jail</h3><p style="color: var(--charcoal); opacity: 0.8;">Call the jail at <strong>(405) 372-4171</strong> to verify the person is still at this facility and hasn't been transferred yet.</p></div></div>
        <div class="reveal reveal-delay-1" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">2</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Call Angel Bail Bonds Immediately</h3><p style="color: var(--charcoal); opacity: 0.8;">Call <strong>(405) 614-3000</strong> — we're available 24/7 and minutes away. We'll confirm the bail amount and begin processing right away.</p></div></div>
        <div class="reveal reveal-delay-2" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">3</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Pay the 10% Premium</h3><p style="color: var(--charcoal); opacity: 0.8;">Sign the bond agreement and pay 10% of the bail amount. We accept cash, credit cards, and offer payment plans.</p></div></div>
        <div class="reveal reveal-delay-3" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">4</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Release Before Transfer</h3><p style="color: var(--charcoal); opacity: 0.8;">We post the bond immediately. Getting the bond posted at Stillwater City Jail avoids the longer processing times at Payne County Detention Center.</p></div></div>
      </div>
    </div>
  </section>

  <section style="padding: 80px 0; background: var(--cream);">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Common Questions</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--agate);">Stillwater City Jail Bail FAQ</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>How long do inmates stay at Stillwater City Jail?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Stillwater City Jail is a 23-bed short-term holding facility. Inmates usually stay less than 72 hours before being released or transferred to the Payne County Detention Center for longer-term holding. This is why posting bail quickly is so important.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>What's the difference between Stillwater City Jail and Payne County Detention Center?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Stillwater City Jail (723 S Lewis St) is a small, short-term holding facility run by the Stillwater Police Department. The Payne County Detention Center (606 S Husband St) is the larger county facility run by the Sheriff's Office. City arrests often start at the city jail and transfer to the county facility within 72 hours.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>Can I bail someone out of Stillwater City Jail at night?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Yes. Angel Bail Bonds operates 24/7. While the court clerk's office has business hours, bail bondsmen can post bonds at any time. Call us at (405) 614-3000 no matter what time it is.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>What forms of payment do you accept?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">We accept cash, credit cards, and debit cards. We also offer flexible payment plans so finances don't have to delay getting your loved one released. The standard bail bond premium in Oklahoma is 10% of the total bail amount.</p></details>
      </div>
    </div>
  </section>

  <section style="background: linear-gradient(135deg, #1a6b6a 0%, #145453 100%); padding: 80px 0;" class="text-cream">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="section-label" style="color: var(--gold);">Don't Wait for a Transfer</p>
      <h2 class="font-display text-3xl md:text-4xl mb-6">Someone at Stillwater City Jail Right Now?</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">Posting bail before the 72-hour transfer window means a faster release. Call Angel Bail Bonds now — we're minutes away.</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.3rem; padding: 16px 40px;">(405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
