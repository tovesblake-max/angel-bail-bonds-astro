---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Noble County Jail',
  url: 'https://stillwaterokbailbonds.com/noble-county-jail-perry-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/noble-county-jail-perry-bail-bonds#business',
  description: 'Bail bond services for Noble County Jail in Perry, Oklahoma. 24/7 availability, fast processing, competitive rates.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: { '@type': 'PostalAddress', streetAddress: '721 Cedar St', addressLocality: 'Perry', addressRegion: 'OK', postalCode: '73077', addressCountry: 'US' },
  geo: { '@type': 'GeoCoordinates', latitude: 36.2893, longitude: -97.2884 },
  areaServed: { '@type': 'AdministrativeArea', name: 'Noble County, Oklahoma' },
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I bail someone out of Noble County Jail in Perry, Oklahoma?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Noble County from Stillwater and can post bonds at the Noble County Jail in Perry. You\'ll need the inmate\'s name and charges. We handle all paperwork and offer competitive rates.' } },
    { '@type': 'Question', name: 'What is Noble County Jail\'s phone number and address?', acceptedAnswer: { '@type': 'Answer', text: 'Noble County Jail is located at 721 Cedar St, Perry, Oklahoma 73077. You can reach them at (580) 336-1001 for inmate information, bail amounts, and general inquiries. They are available 24 hours a day.' } },
    { '@type': 'Question', name: 'What are the visitation hours at Noble County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Contact the jail at (580) 336-1001 for current visitation schedule and requirements. A valid government-issued photo ID is required.' } },
    { '@type': 'Question', name: 'What forms of payment does Noble County Jail accept for bail?', acceptedAnswer: { '@type': 'Answer', text: 'Noble County Jail accepts cash, credit cards, and money orders for direct bail payment. If using a bail bondsman like Angel Bail Bonds, we offer competitive rates and accept cash and credit cards.' } }
  ]
};

const howToData = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Bail Someone Out of Noble County Jail in Perry, OK',
  description: 'Complete guide to posting bail at Noble County Jail in Perry, Oklahoma.',
  step: [
    { '@type': 'HowToStep', name: 'Get inmate information', text: 'Call Noble County Jail at (580) 336-1001 to get the inmate\'s name, charges, and bail amount.' },
    { '@type': 'HowToStep', name: 'Call Angel Bail Bonds', text: 'Call (405) 614-3000. We serve Noble County from nearby Stillwater and can post bonds quickly.' },
    { '@type': 'HowToStep', name: 'Pay premium and sign', text: 'Sign the bond agreement and pay the premium. Competitive rates available.' },
    { '@type': 'HowToStep', name: 'Bond posted and inmate released', text: 'We post the bond at Noble County Jail and the release process begins.' }
  ]
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Noble County Bail Bonds', item: 'https://stillwaterokbailbonds.com/noble-county-bail-bonds' },
    { '@type': 'ListItem', position: 3, name: 'Noble County Jail', item: 'https://stillwaterokbailbonds.com/noble-county-jail-perry-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Noble County Jail Bail Bonds Perry OK | 24/7 Service"
  description="Need bail bonds for Noble County Jail in Perry, Oklahoma? Angel Bail Bonds serves Noble County 24/7. Fast processing, competitive rates. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Noble County Jail — Perry, OK</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Noble County Jail</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">721 Cedar St, Perry, OK 73077 · Served 24/7 from Stillwater</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Facility Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="https://www.google.com/maps/search/?api=1&query=721+Cedar+St+Perry+OK+73077" target="_blank" rel="noopener" style="color: var(--blue); text-decoration: none;">721 Cedar St, Perry, OK 73077</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+15803361001" style="color: var(--blue); text-decoration: none;">(580) 336-1001</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Contact jail for schedule · Photo ID required</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Bail Out -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Bail Someone Out</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Get bail amount</strong><br><span style="color: var(--slate-500);">Call (580) 336-1001 (24/7)</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call us 24/7</strong><br><span style="color: var(--slate-500);">Angel Bail Bonds: (405) 614-3000</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay premium &amp; sign</strong><br><span style="color: var(--slate-500);">Cash, cards accepted</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">We keep you updated</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- ABOUT NOBLE COUNTY JAIL — unique local content -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.3rem; font-weight: 700; margin-bottom: 16px;">About Noble County Jail in Perry</h2>
      <div style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7;">
        <p style="margin-bottom: 14px;">Noble County Jail is located at 721 Cedar St in Perry, Oklahoma 73077, and is operated by the Noble County Sheriff's Office. The jail serves as the primary detention facility for all of Noble County, handling bookings from Perry Police Department, Noble County Sheriff's deputies, and other law enforcement agencies operating within the county. The facility is situated near the Noble County Courthouse, making it convenient for court proceedings and bond hearings.</p>
        <p style="margin-bottom: 14px;">Perry is a small community of roughly 5,000 people located at the crossroads of I-35 and US-64 in north-central Oklahoma. The town is best known for the Cherokee Strip Museum and hosting the annual Cherokee Strip Celebration each September. The jail is located in the downtown area near the courthouse. When picking up a released inmate, the easiest approach is to take Exit 185 off I-35, head west on Fir Ave into Perry, then turn south on 7th St to Cedar St. The facility has a small parking area available for visitors.</p>
        <p style="margin-bottom: 14px;">Because Perry is only about 25 miles north of Stillwater, Noble County Jail is one of the closest out-of-county facilities we serve. Angel Bail Bonds can typically arrive at Noble County Jail within 30 minutes of receiving your call. We have posted bonds at this facility many times and are familiar with the jail staff, their processing procedures, and how to expedite releases. If your loved one has been arrested in Perry, along I-35, or anywhere in Noble County, call us immediately at (405) 614-3000 so we can begin the bail process right away.</p>
      </div>

      <h3 style="color: var(--navy); font-size: 1.1rem; font-weight: 700; margin-top: 28px; margin-bottom: 12px;">What to Expect After an Arrest in Noble County</h3>
      <p style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7; margin-bottom: 14px;">After an arrest in Noble County, the individual is transported to Noble County Jail in Perry for booking. During booking, the person is fingerprinted, photographed, and their personal information is recorded. Bail is typically set according to a standard bond schedule for common charges, though a judge may set a different amount during a bond hearing. Once bail is set, you can call Angel Bail Bonds to post the bond. We handle all the paperwork and coordinate directly with the jail. Most releases from Noble County Jail take 1-4 hours after the bond is posted, depending on the facility's processing workload at the time.</p>
    </div>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I bail someone out of Noble County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000. We serve Noble County from Stillwater and can post bonds at the Noble County Jail in Perry. You'll need the inmate's name and charges. We handle all paperwork and offer competitive rates.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What is Noble County Jail's phone number?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Noble County Jail can be reached 24/7 at (580) 336-1001. They can provide inmate information, bail amounts, and booking details.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I visit someone at Noble County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Contact the jail at (580) 336-1001 for current visitation schedule and requirements. A valid government-issued photo ID is required.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What payment methods does Noble County Jail accept for bail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">For paying the full bail directly, Noble County Jail accepts cash, credit cards, and money orders. If you use Angel Bail Bonds, we offer competitive rates and accept cash and credit cards.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/noble-county-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Noble County Bail Bonds →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Someone in Noble County Jail?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">24/7 availability · Competitive rates · About 30 minutes from Stillwater</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
