      'address': {
        '@type': 'PostalAddress',
        'streetAddress': '119 S Main St',
        'addressLocality': 'Kingfisher',
        'addressRegion': 'OK',
        'postalCode': '73750',
        'addressCountry': 'US'
      },
      'telephone': '(405) 614-3000',
      'email': 'bailbondangel@gmail.com',
      'url': 'https://stillwaterokbailbonds.com/kingfisher-county-bail-bonds',
      'aggregateRating': {
        '@type': 'AggregateRating',
        'ratingValue': '4.9',
        'reviewCount': '127'
      },
      'serviceArea': {
        '@type': 'City',
        'name': 'Kingfisher County, OK',
        'geo': {
          '@type': 'GeoCoordinates',
          'latitude': '35.8614',
          'longitude': '-97.9317'
        }
      },
      'openingHoursSpecification': {
        '@type': 'OpeningHoursSpecification',
        'dayOfWeek': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        'opens': '00:00',
        'closes': '23:59'
      },
      'paymentAccepted': ['Cash', 'Credit Card', 'Zelle', 'Venmo'],
      'priceRange': '$$'
    },
    {
      '@type': 'Service',
      '@id': 'https://stillwaterokbailbonds.com/kingfisher-county-bail-bonds#bail-bonds-service',
      'name': 'Bail Bond Services',
      'description': 'Emergency bail bond services available 24/7 for inmates at Kingfisher County Jail. Video-only visitation available.',
