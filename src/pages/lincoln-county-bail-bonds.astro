---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/lincoln-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Lincoln County',
      url: 'https://stillwaterokbailbonds.com/lincoln-county-bail-bonds',
      description: 'Professional bail bond services for Lincoln County, Oklahoma. 24/7 emergency bail bonds with 15+ years experience.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Lincoln County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 35.7012, longitude: -96.8808 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
    },
    {
      '@type': 'Service',
      name: 'Lincoln County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/lincoln-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Lincoln County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Lincoln County arrests and jail releases.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Lincoln County Bail Bonds', item: 'https://stillwaterokbailbonds.com/lincoln-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I get a bail bond in Lincoln County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Lincoln County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Lincoln County?',
          acceptedAnswer: { '@type': 'Answer', text: 'In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Lincoln County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Lincoln County Jail occur within 1-4 hours depending on jail processing.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Lincoln County Bail Bonds"
  description="24/7 bail bond services for Lincoln County, Oklahoma. Angel Bail Bonds offers fast, confidential bail bond processing. 15+ years experience, 4.9 stars. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Lincoln County, Oklahoma</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Lincoln County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Chandler, Prague, Stroud, Meeker, and surrounding areas · 24/7 service</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: County Info -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Lincoln County Overview</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">County Seat</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Chandler</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Major Communities</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Prague, Stroud, Meeker</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Service Area</td>
            <td style="padding: 10px 0; color: var(--slate-700);">East of OKC · Central OK</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Get Bail Bond -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Get Bail in Lincoln County</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Contact jail</strong><br><span style="color: var(--slate-500);">Get inmate info & bail amount</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call Angel Bail Bonds</strong><br><span style="color: var(--slate-500);">(405) 614-3000 · 24/7</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay premium & sign</strong><br><span style="color: var(--slate-500);">Cash, cards accepted</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">1-4 hours processing time</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- ABOUT LINCOLN COUNTY — unique local content -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.3rem; font-weight: 700; margin-bottom: 16px;">About Lincoln County, Oklahoma</h2>
      <div style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7;">
        <p style="margin-bottom: 14px;">Lincoln County is located in central Oklahoma, directly south of Payne County. With a population of roughly 35,000, the county covers about 960 square miles of gently rolling terrain between Oklahoma City and Tulsa. The county seat is Chandler, a historic Route 66 town located along SH-66 about 50 miles south of Stillwater. Other communities we serve throughout Lincoln County include Stroud, Prague, Meeker, Davenport, Carney, Agra, Sparks, Tryon, and Warwick.</p>
        <p style="margin-bottom: 14px;">Stroud is one of the larger towns in Lincoln County, situated right along the Turner Turnpike (I-44) between Oklahoma City and Tulsa. Arrests on the turnpike within Lincoln County are processed through the Lincoln County system. Prague, another key community, lies in the southeastern part of the county and is known as the hometown of Jim Thorpe. Meeker, in the southern part of the county, rounds out the main population centers.</p>
        <p style="margin-bottom: 14px;">Lincoln County criminal cases are handled by the Lincoln County District Court in Chandler. The Lincoln County Courthouse is located at 811 Manvel Ave in Chandler, the same complex that houses the county jail. Bail amounts in Lincoln County follow Oklahoma's standard bond schedules, with misdemeanor and felony bail amounts varying by the severity of the charge. Angel Bail Bonds regularly works with the Lincoln County court system and jail staff, so we understand the local procedures and can move quickly to get your loved one released.</p>
      </div>

      <h3 style="color: var(--navy); font-size: 1.1rem; font-weight: 700; margin-top: 28px; margin-bottom: 12px;">Communities We Serve in Lincoln County</h3>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px;">
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Chandler</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Stroud</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Prague</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Meeker</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Davenport</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Carney</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Agra</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Sparks</span>
        <span style="background: white; border: 1px solid var(--slate-200); border-radius: 6px; padding: 6px 14px; font-size: 0.85rem; color: var(--slate-700);">Warwick</span>
      </div>
    </div>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I get a bail bond in Lincoln County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Lincoln County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How much does a bail bond cost in Lincoln County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How long does it take to get released from Lincoln County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Lincoln County Jail occur within 1-4 hours depending on jail processing.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Can you help with a turnpike arrest in Lincoln County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Yes. Many arrests in Lincoln County happen on the Turner Turnpike (I-44) near Stroud or Chandler. These are processed through the Lincoln County system. Call Angel Bail Bonds at (405) 614-3000 and we will handle the bail process for any Lincoln County arrest, including those on the turnpike.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/lincoln-county-jail-chandler-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Lincoln County Jail (Chandler) →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Need a Lincoln County Bail Bond?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Women-owned · 15+ years · 4.9 stars · Competitive rates</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
