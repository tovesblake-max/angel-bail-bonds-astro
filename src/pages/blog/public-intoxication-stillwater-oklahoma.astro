              <td style="color: var(--slate-700); padding: 14px 16px;">City Ordinance</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">Misdemeanor</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">$500 &ndash; $1,500</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--slate-200);">
              <td style="color: var(--slate-700); padding: 14px 16px; font-weight: 500;">Minor in Possession</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">37A O.S. &sect;6-101</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">Misdemeanor</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">$500 &ndash; $1,500</td>
            </tr>
            <tr style="background: var(--slate-50); border-bottom: 1px solid var(--slate-200);">
              <td style="color: var(--slate-700); padding: 14px 16px; font-weight: 500;">Open Container</td>
