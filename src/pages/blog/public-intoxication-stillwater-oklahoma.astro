              <td style="color: var(--slate-700); padding: 14px 16px;">Infraction / Misdemeanor</td>
              <td style="color: var(--slate-700); padding: 14px 16px;">$100 &ndash; $500</td>
            </tr>
            <tr>
              <td style="color: var(--slate-700); padding: 14px 16px; font-weight: 500;">PI + Resisting Arrest</td>
