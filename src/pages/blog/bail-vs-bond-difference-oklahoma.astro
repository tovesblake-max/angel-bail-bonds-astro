      }
    },
    {
      "@type": "Question",
      "name": "What happens if someone skips bail in Oklahoma?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If a defendant skips bail (fails to appear in court), the court issues a bench warrant for their arrest and the bail is forfeited. With a cash bond, the person who posted bail loses the entire amount. With a surety bond, the bail bond company becomes responsible for paying the full bail to the court, and will use a recovery agent to locate the defendant. The person who signed for the bond may also be held financially responsible."
      }
    }
