const description = "Learn how to check for outstanding warrants in Oklahoma, what happens when you're arrested on a warrant, bench vs arrest warrants, FTA warrants, and how Angel Bail Bonds can help.";
const canonical = "https://stillwaterokbailbonds.com/blog/warrant-arrest-oklahoma-bail-bonds";
