    'jobTitle': 'Owner & Licensed Bail Bondsman',
    'worksFor': {
      '@type': 'LocalBusiness',
      'name': 'Angel Bail Bonds',
      'telephone': '(405) 614-3000',
      'url': 'https://stillwaterokbailbonds.com'
    }
  },
  'publisher': {
    '@type': 'Organization',
    'name': 'Angel Bail Bonds',
    'url': 'https://stillwaterokbailbonds.com',
    'logo': {
      '@type': 'ImageObject',
      'url': 'https://stillwaterokbailbonds.com/images/angel-bail-bonds-logo.webp'
    }
  },
  'datePublished': publishedDate,
  'dateModified': modifiedDate,
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': canonical
  },
  'articleSection': category,
  'wordCount': 2300,
  'keywords': 'outstanding warrant Oklahoma, warrant arrest bail bonds, bench warrant Oklahoma, FTA warrant Payne County'
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {
      '@type': 'ListItem',
      'position': 1,
      'name': 'Home',
      'item': 'https://stillwaterokbailbonds.com/'
    },
    {
      '@type': 'ListItem',
      'position': 2,
      'name': 'Blog',
      'item': 'https://stillwaterokbailbonds.com/blog'
    },
    {
      '@type': 'ListItem',
      'position': 3,
      'name': title,
      'item': canonical
