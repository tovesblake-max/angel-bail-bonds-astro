---

<BaseLayout
  title="Blog"
  description="Read articles about bail bonds, the legal process, and how to navigate arrest in Central Oklahoma."
  structuredData={breadcrumbData}
>
  <!-- Hero -->
  <section style="background: var(--navy-deep);" class="text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl mb-4 text-white">Blog</h1>
      <p class="text-lg max-w-2xl mx-auto text-white" style="opacity: 0.9;">
        Resources and insights about bail bonds and the legal process
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="section-padding" style="background: var(--slate-50);">
    <div class="max-w-4xl mx-auto">
      <div class="space-y-8">
        {blogPosts.map((post) => (
          <article class="card bg-white hover:shadow-xl transition-shadow">
            <div class="flex justify-between items-start gap-4 mb-4">
              <div>
                <h2 class="text-agate font-display text-2xl hover:text-gold transition-colors">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                <p class="text-charcoal/60 text-sm mt-2">
                  {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} • By {post.author}
                </p>
              </div>
              <span class="bg-gold/20 text-agate px-3 py-1 rounded text-sm font-semibold whitespace-nowrap">
                {post.category}
              </span>
            </div>

            <p class="text-charcoal/80 mb-4">{post.excerpt}</p>

            <a 
              href={`/blog/${post.slug}`}
              class="inline-block text-gold font-semibold hover:text-agate transition-colors"
            >
              Read More →
            </a>
          </article>
        ))}
      </div>

      {blogPosts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-charcoal/80 text-lg">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Categories -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-agate font-display text-3xl mb-8 text-center">Categories</h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="text-center p-6 rounded-lg hover:shadow-lg transition-shadow cursor-pointer" style="background: var(--slate-50);">
          <p class="text-3xl mb-2">📘</p>
          <h3 class="font-semibold" style="color: var(--navy);">Guides</h3>
          <p style="color: var(--slate-500);" class="text-sm mt-2">8 step-by-step guides for bail &amp; arrest</p>
        </div>

        <div class="text-center p-6 rounded-lg hover:shadow-lg transition-shadow cursor-pointer" style="background: var(--slate-50);">
          <p class="text-3xl mb-2">⚖️</p>
          <h3 class="font-semibold" style="color: var(--navy);">Legal Info</h3>
          <p style="color: var(--slate-500);" class="text-sm mt-2">9 articles on Oklahoma bail law</p>
        </div>

        <div class="text-center p-6 rounded-lg hover:shadow-lg transition-shadow cursor-pointer" style="background: var(--slate-50);">
          <p class="text-3xl mb-2">💡</p>
          <h3 class="font-semibold" style="color: var(--navy);">Tips & Advice</h3>
          <p style="color: var(--slate-500);" class="text-sm mt-2">3 articles on costs &amp; cosigning</p>
        </div>

        <div class="text-center p-6 rounded-lg hover:shadow-lg transition-shadow cursor-pointer" style="background: var(--slate-50);">
          <p class="text-3xl mb-2">📍</p>
          <h3 class="font-semibold" style="color: var(--navy);">Local Info</h3>
          <p style="color: var(--slate-500);" class="text-sm mt-2">Payne County &amp; Stillwater specifics</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding text-white" style="background: var(--navy-deep);">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl mb-6 text-white">Need Help Right Now?</h2>
      <p class="text-lg mb-8 text-white" style="opacity: 0.9;">
        Don't wait for information. Contact Angel Bail Bonds immediately for 24/7 emergency services.
      </p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.1rem; padding: 14px 32px;">(405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
