              <th style="color: white; padding: 14px 20px; text-align: left; font-weight: 600; font-size: 0.9375rem; width: 35%;">Consequence of Failure</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--slate-200);">
