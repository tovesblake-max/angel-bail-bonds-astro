            </tr>
            <tr style="border-bottom: 1px solid var(--slate-200); background: var(--slate-50);">
              <td style="padding: 14px 16px; color: var(--slate-700);">A&amp;B with Dangerous Weapon</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">21 O.S. &sect;645</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">Felony</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">$10,000 &ndash; $50,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--slate-200);">
              <td style="padding: 14px 16px; color: var(--slate-700);">Aggravated A&amp;B</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">21 O.S. &sect;646</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">Felony</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">$15,000 &ndash; $50,000+</td>
            </tr>
