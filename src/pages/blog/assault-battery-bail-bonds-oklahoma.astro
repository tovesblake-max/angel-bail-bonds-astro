              <td style="padding: 14px 16px; color: var(--slate-700);">$10,000 &ndash; $35,000</td>
            </tr>
            <tr>
              <td style="padding: 14px 16px; color: var(--slate-700);">Domestic A&amp;B</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">21 O.S. &sect;644.1</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">Misdemeanor / Felony</td>
              <td style="padding: 14px 16px; color: var(--slate-700);">$2,500 &ndash; $25,000+</td>
            </tr>
