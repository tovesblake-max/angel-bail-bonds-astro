              <td style="color: var(--slate-700); padding: 14px 16px;">$2,500 &ndash; $10,000+</td>
            </tr>
            <tr style="background: var(--slate-50);">
              <td style="color: var(--slate-700); padding: 14px 16px; font-weight: 500;">Larceny from Person</td>
