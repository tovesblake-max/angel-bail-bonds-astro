      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': 'https://stillwaterokbailbonds.com/blog/osu-student-arrested-parents-guide',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://stillwaterokbailbonds.com/blog' },
        { '@type': 'ListItem', position: 3, name: 'OSU Student Arrested: Parent\'s Guide', item: 'https://stillwaterokbailbonds.com/blog/osu-student-arrested-parents-guide' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Can I bail my college student out of jail from out of state?',
          acceptedAnswer: {
            '@type': 'Answer',
