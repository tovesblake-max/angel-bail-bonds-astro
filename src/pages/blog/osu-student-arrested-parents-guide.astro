---
import BaseLayout from '../../layouts/BaseLayout.astro';

const publishedDate = new Date('2026-03-07');
const formattedDate = publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: 'OSU Student Arrested in Stillwater: A Parent\'s Guide',
      description: 'A comprehensive guide for parents whose college student has been arrested in Stillwater, Oklahoma. Learn about common student charges, bail bonds, the OSU Student Conduct process, and how to handle everything — even from out of state.',
      author: { '@type': 'Person', name: 'Karri McBride' },
      publisher: {
        '@type': 'Organization',
