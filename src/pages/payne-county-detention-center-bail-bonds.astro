---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  url: 'https://stillwaterokbailbonds.com/payne-county-detention-center-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/payne-county-detention-center-bail-bonds#business',
  name: 'Angel Bail Bonds - Payne County Detention Center',
  description: 'Fast bail bond services for the Payne County Detention Center at 606 S Husband St, Stillwater, OK 74074. Available 24/7 with immediate response.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '606 S Husband St',
    addressLocality: 'Stillwater',
    addressRegion: 'OK',
    postalCode: '74074',
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: 36.1156, longitude: -97.0584 },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Payne County, Oklahoma'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127'
  },
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '00:00',
    closes: '23:59'
  }
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I bail someone out of the Payne County Detention Center?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call Angel Bail Bonds at (405) 614-3000. We need the inmate\'s full name, booking number, and charges. We handle the paperwork and post the bond directly at the detention center. Most releases take 1-2 hours after the bond is posted.'
      }
    },
    {
      '@type': 'Question',
      name: 'Where do I pay bail for Payne County Detention Center inmates?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cash bail can be paid at the Payne County Court Clerk\'s office (Suite 207, 606 S Husband St, Stillwater) Monday-Friday 8am-5pm. After hours, exact cash is accepted at the detention center itself. Or call Angel Bail Bonds and we handle everything for you 24/7.'
      }
    },
    {
      '@type': 'Question',
      name: 'What are the visitation hours at Payne County Detention Center?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In-person visitation is available on Wednesdays with 15-minute visits at the Sheriff\'s Office lobby kiosk (free). Remote video visitation through CityTeleCoin is available daily. Register at CityTeleCoin.com to schedule visits.'
      }
    },
    {
      '@type': 'Question',
      name: 'How much does a bail bond cost at Payne County Detention Center?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oklahoma law sets the bail bond premium at 10% of the total bail amount. For a $5,000 bail, you pay $500. For a $10,000 bail, you pay $1,000. Angel Bail Bonds also offers flexible payment plans so finances don\'t delay your loved one\'s release.'
      }
    },
    {
      '@type': 'Question',
      name: 'How do I look up an inmate at Payne County Detention Center?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Search the online inmate roster at paynecountyok.gov/inmate-search (updated hourly) or call the detention center at (405) 372-4522. You\'ll need the inmate\'s name to look up their booking info, charges, and bail amount.'
      }
    }
  ]
};

const howToData = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Bail Someone Out of Payne County Detention Center',
  description: 'Step-by-step guide to posting bail and getting someone released from the Payne County Detention Center in Stillwater, Oklahoma.',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Get the inmate information',
      text: 'Find the inmate\'s full legal name, booking number, and charges. Search paynecountyok.gov/inmate-search or call (405) 372-4522.'
    },
    {
      '@type': 'HowToStep',
      name: 'Contact Angel Bail Bonds',
      text: 'Call (405) 614-3000 any time, 24/7. Provide the inmate details and we\'ll confirm the bail amount and explain your options.'
    },
    {
      '@type': 'HowToStep',
      name: 'Complete the bond agreement',
      text: 'Sign the bail bond agreement and pay the 10% premium. We accept cash, credit cards, and offer payment plans.'
    },
    {
      '@type': 'HowToStep',
      name: 'Bond is posted at the detention center',
      text: 'We post the bond directly with Payne County Detention Center staff. Processing typically takes 30-60 minutes.'
    },
    {
      '@type': 'HowToStep',
      name: 'Inmate is released',
      text: 'The inmate is processed out and released. Total time from bond posting to release is typically 1-2 hours at Payne County.'
    }
  ]
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Payne County Jail Bail Bonds', item: 'https://stillwaterokbailbonds.com/payne-county-jail-bail-bonds' },
    { '@type': 'ListItem', position: 3, name: 'Payne County Detention Center', item: 'https://stillwaterokbailbonds.com/payne-county-detention-center-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Payne County Detention Center Bail Bonds | 24/7 Fast Release"
  description="Need bail bonds for Payne County Detention Center at 606 S Husband St, Stillwater OK? Angel Bail Bonds posts bonds 24/7 with 1-2 hour release times. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Payne County Detention Center — Stillwater, OK</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Payne County Detention Center</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">606 S Husband St, Stillwater, OK 74074 · 24/7 availability</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Facility Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="https://www.google.com/maps/search/?api=1&query=606+S+Husband+St+Stillwater+OK+74074" target="_blank" rel="noopener" style="color: var(--blue); text-decoration: none;">606 S Husband St, Stillwater, OK 74074</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+14053724522" style="color: var(--blue); text-decoration: none;">(405) 372-4522</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Wed 15-min · Video daily via CityTeleCoin</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">10% premium · Payment plans available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Bail Out -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Bail Someone Out</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Get bail amount</strong><br><span style="color: var(--slate-500);">Call (405) 372-4522 or search paynecountyok.gov</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call us 24/7</strong><br><span style="color: var(--slate-500);">Angel Bail Bonds: (405) 614-3000</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay 10% &amp; sign</strong><br><span style="color: var(--slate-500);">Cash, cards, or payment plan</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">1-2 hour release time</span></div>
          </li>
        </ol>
      </div>
    </div>

    <!-- Responsive: stack columns on mobile -->
    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I bail someone out of Payne County Detention Center?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000. We need the inmate's full name, booking number, and charges. We handle the paperwork and post the bond directly at the detention center. Most releases take 1-2 hours after the bond is posted.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Where do I pay bail for Payne County Detention Center inmates?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Cash bail can be paid at the Payne County Court Clerk's office (Suite 207, 606 S Husband St, Stillwater) Monday-Friday 8am-5pm. After hours, exact cash is accepted at the detention center itself. Or call Angel Bail Bonds and we handle everything for you 24/7.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What are visitation hours at Payne County Detention Center?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">In-person visitation is available on Wednesdays with 15-minute visits at the Sheriff's Office lobby kiosk (free). Remote video visitation through CityTeleCoin is available daily. Register at CityTeleCoin.com to schedule visits.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How much does a bail bond cost?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Oklahoma law sets the bail bond premium at 10% of the total bail amount. For a $5,000 bail, you pay $500. For a $10,000 bail, you pay $1,000. Angel Bail Bonds also offers flexible payment plans.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I look up an inmate at Payne County Detention Center?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Search the online inmate roster at paynecountyok.gov/inmate-search (updated hourly) or call the detention center at (405) 372-4522. You'll need the inmate's name to look up their booking info, charges, and bail amount.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/payne-county-jail-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Payne County Jail →</a>
        <a href="/stillwater-city-jail-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Stillwater City Jail →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Someone in Payne County Detention Center?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">24/7 availability · Payment plans · Serve all of Payne County</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
