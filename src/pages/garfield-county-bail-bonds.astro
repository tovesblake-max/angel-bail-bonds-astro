<BaseLayout
  title="Garfield County Bail Bonds | 24/7 Jail Release in Enid, OK"
  description="Need a bail bond in Garfield County? Angel Bail Bonds provides 24/7 fast release from Garfield County Detention Center in Enid, OK. Serving Enid, Covington, Drummond, Waukomis & Vance AFB area. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
