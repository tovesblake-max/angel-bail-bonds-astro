        { "@type": "City", "name": "Enid" },
        { "@type": "City", "name": "North Enid" },
        { "@type": "City", "name": "Covington" },
        { "@type": "City", "name": "Drummond" },
        { "@type": "City", "name": "Lahoma" },
        { "@type": "City", "name": "Waukomis" },
        { "@type": "City", "name": "Hunter" },
        { "@type": "City", "name": "Garber" },
        { "@type": "City", "name": "Kremlin" },
        { "@type": "City", "name": "Carrier" },
        { "@type": "City", "name": "Hillsdale" },
        { "@type": "City", "name": "Fairmont" },
        { "@type": "City", "name": "Douglas" },
        { "@type": "City", "name": "Breckinridge" }
      ],
      "geo": { "@type": "GeoCoordinates", "latitude": "36.3956", "longitude": "-97.8784" },
      "priceRange": "Varies",
      "paymentMethod": ["Cash", "Credit Card", "Zelle", "Venmo"],
