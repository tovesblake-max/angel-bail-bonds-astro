            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 120px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);">1020 S 10th St, Enid, OK 73701</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Jail Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+15805482429" style="color: var(--blue);">(580) 548-2429</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Capacity</td>
            <td style="padding: 10px 0; color: var(--slate-700);">204 inmates · Medium security</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bookings</td>
            <td style="padding: 10px 0; color: var(--slate-700);">~880/year (~4/day)</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Staff</td>
            <td style="padding: 10px 0; color: var(--slate-700);">99 officers</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Operated By</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Garfield County Criminal Trust Authority</td>
          </tr>
