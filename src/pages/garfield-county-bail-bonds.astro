---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/garfield-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Garfield County',
      url: 'https://stillwaterokbailbonds.com/garfield-county-bail-bonds',
      description: 'Professional 24/7 bail bond services for Garfield County, Oklahoma. Serving Enid, Covington, Drummond, Lahoma, Waukomis, Garber, Hunter, and all Garfield County communities. 15+ years experience, 4.9-star rating.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Garfield County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 36.3956, longitude: -97.8784 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
      openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' },
      paymentAccepted: 'Cash, Visa, Mastercard, Zelle, Venmo',
      priceRange: '$$',
    },
    {
      '@type': 'Service',
      name: 'Garfield County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/garfield-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Garfield County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Garfield County arrests. Serving the Garfield County Detention Center in Enid with typical release times of 2-6 hours after bond posting.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Garfield County Bail Bonds', item: 'https://stillwaterokbailbonds.com/garfield-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I bail someone out of the Garfield County Detention Center in Enid?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We handle Garfield County bonds and can coordinate posting with the detention center. The Garfield County Detention Center is located at 1020 S 10th Street, Enid, OK. You can also reach the jail directly at (580) 548-2429. Once we post the bond, most releases take 2-6 hours.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Garfield County, Oklahoma?',
          acceptedAnswer: { '@type': 'Answer', text: 'Oklahoma bail bond premiums are regulated by state law. Angel Bail Bonds offers competitive rates with flexible payment options including cash, Visa, Mastercard, Zelle, Venmo, and financing plans for qualifying clients. Call (405) 614-3000 for a free quote on any Garfield County bond.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from the Garfield County Detention Center?',
          acceptedAnswer: { '@type': 'Answer', text: 'After Angel Bail Bonds posts your bond at the Garfield County Detention Center, most defendants are released within 2-6 hours. The facility houses up to 204 inmates, and processing times depend on jail staffing, time of day, and current booking volume. We work to expedite every release.' },
        },
        {
          '@type': 'Question',
          name: 'Where is the Garfield County Courthouse and when are arraignments held?',
          acceptedAnswer: { '@type': 'Answer', text: 'The Garfield County Courthouse is located at 114 W Broadway Ave, Enid, OK 73701. The courthouse is open Monday through Friday, 8:00 AM to 4:30 PM. For specific arraignment schedules and docket information, contact the Court Clerk at (580) 237-0232 or check oscn.net for current docket calendars.' },
        },
        {
          '@type': 'Question',
          name: 'Can Angel Bail Bonds post bail in Garfield County from Stillwater?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds is based in Stillwater, approximately 65 miles from Enid. We handle Garfield County bonds and can often coordinate the entire process remotely by phone. You provide the inmate information and payment, and we work directly with the Garfield County Detention Center to post the bond.' },
        },
        {
          '@type': 'Question',
          name: 'Does Angel Bail Bonds serve Covington, Drummond, and Waukomis?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. We serve every community in Garfield County, including Enid, Covington, Drummond, Lahoma, Waukomis, Hunter, Garber, Kremlin, Carrier, Hillsdale, Fairmont, Douglas, Breckinridge, and North Enid. Anyone arrested within Garfield County is booked at the Garfield County Detention Center in Enid.' },
        },
        {
          '@type': 'Question',
          name: 'What payment methods does Angel Bail Bonds accept for Garfield County bonds?',
          acceptedAnswer: { '@type': 'Answer', text: 'We accept cash, Visa, Mastercard, Zelle, Venmo, and offer financing plans for those who qualify. We work with families to find affordable payment solutions so your loved one can be released from the Garfield County Detention Center as quickly as possible.' },
        },
      ],
    },
  ],
