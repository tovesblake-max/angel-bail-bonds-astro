      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Stillwater",
        "addressRegion": "OK",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "City", "name": "Perry" },
        { "@type": "City", "name": "Billings" },
        { "@type": "City", "name": "Morrison" },
        { "@type": "City", "name": "Red Rock" },
        { "@type": "City", "name": "Marland" },
        { "@type": "City", "name": "Lucien" },
        { "@type": "City", "name": "Ceres" },
        { "@type": "City", "name": "Sumner" }
      ],
      "geo": { "@type": "GeoCoordinates", "latitude": "36.2893", "longitude": "-97.2884" },
      "priceRange": "Varies",
      "paymentMethod": ["Cash", "Credit Card", "Zelle", "Venmo"],
      "hoursOfOperation": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "00:00",
          "closes": "23:59"
        }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127" },
      "sameAs": ["https://g.co/kgs/Angel-Bail-Bonds-Stillwater"]
    },
    {
      "@type": "Service",
      "name": "Noble County Bail Bond Services",
      "provider": { "@id": "https://stillwaterokbailbonds.com/noble-county-bail-bonds#business" },
      "areaServed": "Noble County, Oklahoma",
      "description": "Fast, confidential bail bond services for Noble County arrests. Serving Perry, Billings, Morrison, Red Rock, and all Noble County communities."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stillwaterokbailbonds.com/" },
        { "@type": "ListItem", "position": 2, "name": "Noble County Bail Bonds", "item": "https://stillwaterokbailbonds.com/noble-county-bail-bonds" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I bail someone out of Noble County Jail in Perry, Oklahoma?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We are located just 25 miles south in Stillwater and can often arrive at Noble County Jail at 721 Cedar St, Perry within 30 minutes. We handle all paperwork and most inmates are released within 1-4 hours after the bond is posted."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a bail bond cost in Noble County, Oklahoma?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Noble County bail bond costs depend on the charge. Common bail amounts include approximately $1,000 for misdemeanor DUI, $500-$2,500 for most misdemeanors, and $5,000-$50,000+ for felonies. You pay a percentage of the total bail amount as a non-refundable premium. Angel Bail Bonds accepts cash, Visa, Mastercard, Zelle, Venmo, and offers financing."
          }
        },
        {
          "@type": "Question",
          "name": "What are Noble County Jail visiting hours?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Noble County Jail visiting hours are Monday through Friday 7:30 AM to 9:00 PM and Saturday through Sunday 7:30 AM to 2:30 PM. However, in-person visits have been replaced with video visitation. Visits are limited to 30 minutes. Call (580) 336-3517 to schedule a video visit."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to get released from Noble County Jail?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most releases from Noble County Jail take 1-4 hours after the bail bond is posted, depending on the time of day and how busy the facility is. Noble County Jail processes approximately 4,233 bookings per year. Angel Bail Bonds can begin the bond process over the phone before arriving at the jail to speed up release."
          }
        },
        {
          "@type": "Question",
          "name": "Can I post bail at Noble County Jail at night or on weekends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Angel Bail Bonds is available 24 hours a day, 7 days a week, including nights, weekends, and holidays. Noble County Jail accepts bail bonds around the clock. Call (405) 614-3000 any time and we can begin the release process immediately."
          }
        },
        {
          "@type": "Question",
          "name": "Where is the Noble County Courthouse and when are court appearances?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Noble County Courthouse is located at 300 Courthouse Drive, Perry, OK 73077. The Court Clerk's office phone number is (580) 336-5187 and is open Monday-Friday 8:00 AM to 4:30 PM. Arraignments typically occur within 24 hours of arrest. Court dockets are available at oscn.net."
          }
        },
        {
          "@type": "Question",
          "name": "Does Angel Bail Bonds serve all of Noble County?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Angel Bail Bonds serves every community in Noble County including Perry, Billings, Morrison, Red Rock, Marland, Lucien, Ceres, and Sumner. Our Stillwater office is just 25 miles south of Perry via I-35, making us one of the closest bail bond companies to Noble County."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="Noble County Bail Bonds | 24/7 Jail Release in Perry, OK"
  description="Need a bail bond in Noble County? Angel Bail Bonds provides 24/7 fast jail release from Noble County Jail in Perry, OK. Just 25 miles from Stillwater. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Noble County, Oklahoma</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Noble County Bail Bonds — Fast Jail Release in Perry, OK</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Perry · Billings · Morrison · Red Rock · Marland · Lucien — 24/7 service, just 25 miles from Stillwater</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 Call (405) 614-3000 Now</a>
