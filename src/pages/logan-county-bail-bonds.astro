---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/logan-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Logan County',
      url: 'https://stillwaterokbailbonds.com/logan-county-bail-bonds',
      description: 'Professional 24/7 bail bond services for Logan County, Oklahoma. Serving the Logan County Detention Center in Guthrie with fast releases and competitive rates. Women-owned, 15+ years experience.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: [
        { '@type': 'AdministrativeArea', name: 'Logan County, Oklahoma' },
        { '@type': 'City', name: 'Guthrie, Oklahoma' },
        { '@type': 'City', name: 'Crescent, Oklahoma' },
        { '@type': 'City', name: 'Mulhall, Oklahoma' },
        { '@type': 'City', name: 'Orlando, Oklahoma' },
        { '@type': 'City', name: 'Coyle, Oklahoma' },
        { '@type': 'City', name: 'Marshall, Oklahoma' },
        { '@type': 'City', name: 'Langston, Oklahoma' },
        { '@type': 'City', name: 'Meridian, Oklahoma' },
        { '@type': 'City', name: 'Cashion, Oklahoma' },
        { '@type': 'City', name: 'Seward, Oklahoma' },
      ],
      geo: { '@type': 'GeoCoordinates', latitude: 35.8834, longitude: -97.4262 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      paymentAccepted: ['Cash', 'Visa', 'Mastercard', 'Zelle', 'Venmo'],
      priceRange: 'Competitive rates with financing available',
    },
    {
      '@type': 'Service',
      name: 'Logan County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/logan-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Logan County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Logan County arrests at the Logan County Detention Center in Guthrie, Oklahoma. Available 24/7 including holidays.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Logan County Bail Bonds', item: 'https://stillwaterokbailbonds.com/logan-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I bail someone out of Logan County Jail in Guthrie?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, day or night. We verify charges and bail amount with the Logan County Detention Center at 216 S Broad St in Guthrie, phone (405) 282-4100. We handle all paperwork remotely by phone or e-sign and post bail directly. Most defendants are released within 1-2 hours after bond is posted. The jail has a 198-bed capacity and is operated by the Logan County Sheriff\'s Office under Sheriff Damon Devereaux.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Logan County, Oklahoma?',
          acceptedAnswer: { '@type': 'Answer', text: 'In Logan County, bail amounts are set by the court based on the charges. Typical bail ranges are approximately $1,000 for DUI, $500-$5,000 for misdemeanors, and $5,000-$50,000+ for felonies. Angel Bail Bonds offers competitive premium rates — you pay a percentage of the total bail amount rather than the full cash bail. We accept cash, Visa, Mastercard, Zelle, and Venmo, and offer financing for larger bonds. Call (405) 614-3000 for a free quote.' },
        },
        {
          '@type': 'Question',
          name: 'What are the visiting hours at Logan County Detention Center?',
          acceptedAnswer: { '@type': 'Answer', text: 'Logan County Detention Center visiting hours are Monday through Friday 7:30 AM to 9:00 PM, and Saturday through Sunday 7:30 AM to 2:30 PM. Inmates receive one free 10-minute lobby visit per day. Visits must be scheduled in advance through the Logan County Sheriff\'s Office website or by calling (405) 282-4100. Visitors must sign in at least 15 minutes before their scheduled visit. Visitors under 18 must be accompanied by a parent or legal guardian.' },
        },
        {
          '@type': 'Question',
          name: 'When are arraignments held in Logan County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Logan County arraignments are held every Tuesday and Thursday at 1:30 PM at the Logan County Courthouse, 301 E Harrison St in Guthrie. To be added to the docket, call the Court Clerk at (405) 282-0123 between 8:00 AM and 10:30 AM on the day of the requested appearance. Felony dockets are held the 1st and 3rd Friday at 9:00 AM. The Court Clerk is Cheryl Smith.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Logan County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'After Angel Bail Bonds posts bail at the Logan County Detention Center, most defendants are released within 1-2 hours. Processing includes paperwork verification, property return, and outprocessing. Weekend and holiday releases may take slightly longer due to staffing. The 198-bed facility processes bookings from Guthrie PD, Logan County Sheriff\'s Office, and US Marshals. We stay in contact until your loved one walks out.' },
        },
        {
          '@type': 'Question',
          name: 'Can I bail someone out of Logan County Jail remotely?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds handles the entire Logan County bail process remotely by phone, email, or e-sign. You do not need to visit our office or the jail. We complete paperwork electronically, post bail at the Logan County Detention Center, and keep you updated until release. This is especially helpful for out-of-town families or Langston University students whose families may be in another city.' },
        },
        {
          '@type': 'Question',
          name: 'Do you post bail for Langston University students arrested in Logan County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Langston University is located in Langston, Oklahoma within Logan County. Any arrests in the Langston area are processed through the Logan County Detention Center in Guthrie. Angel Bail Bonds regularly assists Langston University students and their families with bail. We handle everything remotely so out-of-state families can arrange bail by phone. Call (405) 614-3000 any time, 24/7.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Logan County Bail Bonds — 24/7 Jail Release in Guthrie, OK | Angel Bail Bonds"
  description="24/7 bail bonds for Logan County Detention Center in Guthrie, Oklahoma. 198-bed facility, 1-2 hour releases. Serving Guthrie, Langston, Crescent & all Logan County. Women-owned, 15+ years. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Logan County, Oklahoma · Guthrie · Oklahoma's First State Capital</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Logan County Bail Bonds — Guthrie, OK</h1>
