---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/logan-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Logan County',
      url: 'https://stillwaterokbailbonds.com/logan-county-bail-bonds',
      description: 'Professional 24/7 bail bond services for Logan County, Oklahoma. Serving Guthrie, Crescent, Coyle, Mulhall, and all Logan County communities. 15+ years experience, 4.9-star rating.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Logan County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 35.8789, longitude: -97.4253 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
      openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' },
      paymentAccepted: 'Cash, Visa, Mastercard, Zelle, Venmo',
      priceRange: '$$',
    },
    {
      '@type': 'Service',
      name: 'Logan County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/logan-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Logan County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Logan County arrests. Serving the Logan County Jail in Guthrie with typical release times of 1-4 hours after bond posting.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Logan County Bail Bonds', item: 'https://stillwaterokbailbonds.com/logan-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I bail someone out of Logan County Jail in Guthrie?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We handle Logan County bonds daily and can often coordinate posting remotely. The Logan County Jail is located at 216 South Broad Street, Guthrie, OK 73044. Once we post the bond, most releases take 1-4 hours.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Logan County, Oklahoma?',
          acceptedAnswer: { '@type': 'Answer', text: 'Oklahoma bail bond premiums are set by state regulation. Angel Bail Bonds offers competitive rates with flexible payment options including cash, Visa, Mastercard, Zelle, Venmo, and financing plans for qualifying clients.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Logan County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'After Angel Bail Bonds posts your bond at Logan County Jail, most defendants are released within 1-4 hours. Processing times depend on jail staffing, time of day, and booking volume. We work to expedite every release.' },
        },
        {
          '@type': 'Question',
          name: 'When are arraignments held in Logan County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Logan County arraignments are held on Tuesdays and Thursdays at 1:30 PM at the Logan County Courthouse, 301 E. Harrison Street, Guthrie, OK 73044. Contact the Court Clerk at (405) 282-0123 between 8:00 AM and 10:30 AM on the day of the requested appearance.' },
        },
        {
          '@type': 'Question',
          name: 'Can I post bail for someone in Logan County Jail from Stillwater?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds is based in Stillwater, just 33 miles from Guthrie. We regularly post bonds at the Logan County Jail and can often handle the entire process remotely by phone, so you do not need to drive to Guthrie yourself.' },
        },
        {
          '@type': 'Question',
          name: 'Does Angel Bail Bonds serve all of Logan County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. We serve every community in Logan County including Guthrie, Crescent, Coyle, Mulhall, Orlando, Marshall, Cedar Valley, Cimarron City, and Meridian. We also handle bonds for anyone arrested by the Logan County Sheriff within the county limits.' },
        },
        {
          '@type': 'Question',
          name: 'What payment methods does Angel Bail Bonds accept for Logan County bonds?',
          acceptedAnswer: { '@type': 'Answer', text: 'We accept cash, Visa, Mastercard, Zelle, Venmo, and offer financing plans for those who qualify. We work with families to find affordable payment solutions so your loved one can be released quickly.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Logan County Bail Bonds | Guthrie OK | Angel Bail Bonds"
  description="24/7 bail bond services for Logan County, Oklahoma. Serving Guthrie, Crescent, Coyle & all Logan County. Fast jail release, 15+ years experience, 4.9 stars. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Logan County, Oklahoma</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Logan County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Guthrie, Crescent, Coyle, Mulhall &amp; surrounding areas · 24/7 service · Only 33 miles from Stillwater</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Logan County Jail Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 110px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);">216 S. Broad St, Guthrie, OK 73044</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);">(405) 282-4100</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Booking</td>
            <td style="padding: 10px 0; color: var(--slate-700);">24 hours / 7 days a week</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Mon–Fri 7:30 AM – 9:00 PM · Sat–Sun 7:30 AM – 2:30 PM (by appointment, call ahead)</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">County Seat</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Guthrie</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Population</td>
            <td style="padding: 10px 0; color: var(--slate-700);">~49,555 (2020 Census)</td>
          </tr>
        </table>
      </div>

      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Get a Bail Bond in Logan County</h2>
