---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/pawnee-county-bail-bonds#business',
      name: 'Angel Bail Bonds - Pawnee County',
      url: 'https://stillwaterokbailbonds.com/pawnee-county-bail-bonds',
      description: 'Professional bail bond services for Pawnee County, Oklahoma. 24/7 emergency bail bonds with 15+ years experience.',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: { '@type': 'PostalAddress', addressLocality: 'Stillwater', addressRegion: 'OK', addressCountry: 'US' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Pawnee County, Oklahoma' },
      geo: { '@type': 'GeoCoordinates', latitude: 36.3376, longitude: -96.8039 },
      sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
    },
    {
      '@type': 'Service',
      name: 'Pawnee County Bail Bond Services',
      provider: { '@id': 'https://stillwaterokbailbonds.com/pawnee-county-bail-bonds#business' },
      areaServed: { '@type': 'AdministrativeArea', name: 'Pawnee County, Oklahoma' },
      description: 'Fast, confidential bail bond services for Pawnee County arrests and jail releases.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
        { '@type': 'ListItem', position: 2, name: 'Pawnee County Bail Bonds', item: 'https://stillwaterokbailbonds.com/pawnee-county-bail-bonds' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I get a bail bond in Pawnee County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Pawnee County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.' },
        },
        {
          '@type': 'Question',
          name: 'How much does a bail bond cost in Pawnee County?',
          acceptedAnswer: { '@type': 'Answer', text: 'In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.' },
        },
        {
          '@type': 'Question',
          name: 'How long does it take to get released from Pawnee County Jail?',
          acceptedAnswer: { '@type': 'Answer', text: 'Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Pawnee County Jail occur within 1-4 hours depending on jail processing.' },
        },
        {
          '@type': 'Question',
          name: 'Does Angel Bail Bonds serve Cleveland and Ralston in Pawnee County?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Angel Bail Bonds serves all of Pawnee County including Cleveland, Ralston, Jennings, and Terlton. Cleveland is the largest city in the county at about 3,200 residents. No matter where in Pawnee County the arrest occurs, we can post bond at the Pawnee County Jail.' },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Pawnee County Bail Bonds"
  description="24/7 bail bond services for Pawnee County, Oklahoma. Angel Bail Bonds offers fast, confidential bail bond processing. 15+ years experience, 4.9 stars. Call (405) 614-3000."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Pawnee County, Oklahoma</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Pawnee County</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">Pawnee and surrounding areas · North-central Oklahoma · 24/7 service</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: County Info -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Pawnee County Overview</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">County Seat</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Pawnee</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Main City</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Pawnee, Oklahoma</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Service Area</td>
            <td style="padding: 10px 0; color: var(--slate-700);">North-central Oklahoma</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Get Bail Bond -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Get Bail in Pawnee County</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Contact jail</strong><br><span style="color: var(--slate-500);">Get inmate info & bail amount</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call Angel Bail Bonds</strong><br><span style="color: var(--slate-500);">(405) 614-3000 · 24/7</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay premium &amp; sign</strong><br><span style="color: var(--slate-500);">Cash, cards accepted</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">1-4 hours processing time</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- ABOUT PAWNEE COUNTY — unique local content -->
  <section style="padding: 48px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.3rem; font-weight: 700; margin-bottom: 16px;">About Pawnee County, Oklahoma</h2>
      <div style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7;">
        <p style="margin-bottom: 14px;">Pawnee County is located in north-central Oklahoma, northeast of Payne County. With a population of approximately 16,500, the county covers about 595 square miles. The county seat is Pawnee, a historic town of around 2,100 residents that also serves as the capital of the Pawnee Nation. Pawnee County was established in 1893 during the Cherokee Outlet Opening and is named after the Pawnee people, who were relocated to this area from Nebraska in the 1870s.</p>
        <p style="margin-bottom: 14px;">The largest city in Pawnee County is Cleveland, with a population of about 3,200. Cleveland sits along US-64 near the western shore of Keystone Lake and is closer to Stillwater than the city of Pawnee itself. Other communities in the county include Ralston, located along the Arkansas River in the northwestern part of the county, Jennings to the southeast, and Terlton to the south. Angel Bail Bonds serves all of these communities and can post bond at Pawnee County Jail for arrests originating anywhere in the county.</p>
        <p style="margin-bottom: 14px;">All Pawnee County criminal cases are handled through the Pawnee County District Court, located at the Pawnee County Courthouse at 500 Harrison St in Pawnee. For misdemeanor charges, bail is typically set according to a standard bond schedule. Felony charges may require a bond hearing before a judge, which can add time before a bond amount is set. Angel Bail Bonds has handled hundreds of bonds in Pawnee County and understands the local court system well.</p>
      </div>

      <h3 style="color: var(--navy); font-size: 1.1rem; font-weight: 700; margin-top: 28px; margin-bottom: 12px;">Getting to Pawnee County from Stillwater</h3>
      <p style="color: var(--slate-600); font-size: 0.92rem; line-height: 1.7; margin-bottom: 14px;">Pawnee is located about 30 miles northeast of Stillwater. The most direct route is to take SH-51 East from Stillwater, then turn north on SH-18 into the city of Pawnee. The drive takes approximately 40-45 minutes. The Pawnee County Jail is located at 500 Harrison St, near the Pawnee County Courthouse. Because of our proximity in Stillwater, Angel Bail Bonds can often arrive at the jail within an hour of your call. For arrests in Cleveland, the drive from Stillwater is even shorter at around 25-30 minutes via US-64.</p>

      <div style="margin-top: 20px;">
        <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Communities We Serve in Pawnee County</p>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <span style="font-size: 0.8rem; color: var(--slate-500); padding: 4px 12px; background: white; border: 1px solid var(--slate-100); border-radius: 20px;">Pawnee</span>
          <span style="font-size: 0.8rem; color: var(--slate-500); padding: 4px 12px; background: white; border: 1px solid var(--slate-100); border-radius: 20px;">Cleveland</span>
          <span style="font-size: 0.8rem; color: var(--slate-500); padding: 4px 12px; background: white; border: 1px solid var(--slate-100); border-radius: 20px;">Ralston</span>
          <span style="font-size: 0.8rem; color: var(--slate-500); padding: 4px 12px; background: white; border: 1px solid var(--slate-100); border-radius: 20px;">Jennings</span>
          <span style="font-size: 0.8rem; color: var(--slate-500); padding: 4px 12px; background: white; border: 1px solid var(--slate-100); border-radius: 20px;">Terlton</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I get a bail bond in Pawnee County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000 any time, 24/7. We will guide you through the Pawnee County bail process, handle the paperwork, and work to get your loved one released as quickly as possible.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How much does a bail bond cost in Pawnee County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">In Oklahoma, we offer competitive rates on bail bonds. Angel Bail Bonds offers competitive rates to help families manage the cost.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How long does it take to get released from Pawnee County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Release times vary, but once paperwork is filed by Angel Bail Bonds, most releases from Pawnee County Jail occur within 1-4 hours depending on jail processing.</p>
        </details>
        <details style="background: var(--slate-50); border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Does Angel Bail Bonds serve Cleveland and Ralston in Pawnee County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Yes. Angel Bail Bonds serves all of Pawnee County including Cleveland, Ralston, Jennings, and Terlton. Cleveland is the largest city in the county at about 3,200 residents and is only about 25-30 minutes from our Stillwater office. No matter where in Pawnee County the arrest occurs, we can post bond at the Pawnee County Jail.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/pawnee-county-jail-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Pawnee County Jail →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Need a Pawnee County Bail Bond?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Women-owned · 15+ years · 4.9 stars · Competitive rates</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
