---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org', '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Pawnee County Jail',
  description: 'Bail bond services for Pawnee County Jail at 500 Harrison St, Pawnee, OK. 24/7 availability from Stillwater.',
  image: '/images/logo.webp', telephone: '(405) 614-3000',
  address: { '@type': 'PostalAddress', streetAddress: '500 Harrison St', addressLocality: 'Pawnee', addressRegion: 'OK', postalCode: '74058', addressCountry: 'US' },
  areaServed: { '@type': 'AdministrativeArea', name: 'Pawnee County, Oklahoma' },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'How do I bail someone out of Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Pawnee County from Stillwater and can post bonds at the Pawnee County Jail at 500 Harrison St. You pay 10% of the bail amount and we handle all paperwork.' } },
  { '@type': 'Question', name: 'What is the phone number for Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Pawnee County Jail can be reached at (918) 762-2565. The fax number is (918) 762-6407. The jail is located at 500 Harrison Street, Pawnee, OK 74058.' } },
  { '@type': 'Question', name: 'What are visitation hours at Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Visitation hours at Pawnee County Jail are Monday-Friday 7:30 AM to 9:00 PM and Saturday-Sunday 7:30 AM to 2:30 PM. Visits must be scheduled in advance through the sheriff\'s office online portal or by phone.' } },
  { '@type': 'Question', name: 'How much does bail cost at Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Bail amounts vary by charge. Call the jail at (918) 762-2565 for the specific bail amount. When using Angel Bail Bonds, you pay just 10% of the bail as your premium. Payment plans are available.' } }
] };

const howToData = { '@context': 'https://schema.org', '@type': 'HowTo',
  name: 'How to Bail Someone Out of Pawnee County Jail',
  description: 'Step-by-step guide to posting bail at Pawnee County Jail in Pawnee, Oklahoma.',
  step: [
    { '@type': 'HowToStep', name: 'Get inmate details', text: 'Call Pawnee County Jail at (918) 762-2565 for inmate info and bail amount.' },
    { '@type': 'HowToStep', name: 'Call Angel Bail Bonds', text: 'Call (405) 614-3000. We serve Pawnee County and can post bonds at the jail.' },
    { '@type': 'HowToStep', name: 'Pay the 10% premium', text: 'Sign the agreement and pay 10%. Cash, credit cards, and payment plans accepted.' },
    { '@type': 'HowToStep', name: 'Bond posted and release', text: 'We post the bond and the jail processes the release.' }
  ]
};
---

<BaseLayout
  title="Pawnee County Jail Bail Bonds | 500 Harrison St, Pawnee OK"
  description="Need bail bonds for Pawnee County Jail in Pawnee, Oklahoma? Angel Bail Bonds serves Pawnee County 24/7. Fast processing, 10% premium, payment plans. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />

  <section style="background: linear-gradient(135deg, #1a6b6a 0%, #145453 100%); min-height: 50vh;" class="flex items-center text-cream">
    <div class="max-w-7xl mx-auto px-4 py-20 w-full">
      <p class="section-label" style="color: var(--gold);">Pawnee County Jail</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mb-4">Bail Bonds for<br><span style="color: var(--gold);">Pawnee County Jail</span></h1>
      <p class="text-lg md:text-xl max-w-2xl mb-8 opacity-90">500 Harrison Street, Pawnee, OK 74058 — Angel Bail Bonds serves Pawnee County from nearby Stillwater.</p>
      <a href="tel:+14056143000" class="btn-primary"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>(405) 614-3000</a>
    </div>
  </section>

  <section style="background: var(--cream); padding: 80px 0;">
    <div class="max-w-7xl mx-auto px-4">
      <p class="section-label">Facility Details</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--agate);">Pawnee County Jail Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card reveal"><div class="icon-box">📍</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Address</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">500 Harrison Street<br>Pawnee, OK 74058</p></div>
        <div class="card reveal reveal-delay-1"><div class="icon-box">📞</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Phone</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">(918) 762-2565<br>Fax: (918) 762-6407</p></div>
        <div class="card reveal reveal-delay-2"><div class="icon-box">👥</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Visitation</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">M-F: 7:30am - 9:00pm<br>Sat-Sun: 7:30am - 2:30pm</p></div>
        <div class="card reveal reveal-delay-3"><div class="icon-box">💰</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--agate);">Bail Info</h3><p style="color: var(--charcoal); opacity: 0.8; font-size: 0.95rem;">Call (918) 762-2565 for bail amounts<br>Schedule visits online or by phone</p></div>
      </div>
    </div>
  </section>

  <section style="padding: 100px 0; background: white;">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Step-by-Step Guide</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--agate);">How to Bail Someone Out of Pawnee County Jail</h2>
      <p style="color: var(--charcoal); opacity: 0.8; margin-bottom: 48px; font-size: 1.1rem;">Pawnee County Jail is about 45 minutes east of Stillwater. We serve this facility regularly and can post bonds quickly.</p>
      <div style="display: flex; flex-direction: column; gap: 32px;">
        <div class="reveal" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700;">1</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Get the Bail Amount</h3><p style="color: var(--charcoal); opacity: 0.8;">Call Pawnee County Jail at <strong>(918) 762-2565</strong> for the inmate's bail amount and charges. Have their full name ready.</p></div></div>
        <div class="reveal reveal-delay-1" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700;">2</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Call Angel Bail Bonds</h3><p style="color: var(--charcoal); opacity: 0.8;">Call <strong>(405) 614-3000</strong> — available 24/7. We'll confirm the details and explain your options including payment plans.</p></div></div>
        <div class="reveal reveal-delay-2" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700;">3</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Pay the 10% Premium</h3><p style="color: var(--charcoal); opacity: 0.8;">Sign the bond agreement and pay 10% of the bail. We accept cash, credit cards, and offer payment plans.</p></div></div>
        <div class="reveal reveal-delay-3" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--agate); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700;">4</div><div><h3 class="font-display text-xl mb-2" style="color: var(--agate);">Bond Posted — Release Begins</h3><p style="color: var(--charcoal); opacity: 0.8;">We post the bond with Pawnee County Jail and the release process starts. We'll keep you updated throughout.</p></div></div>
      </div>
    </div>
  </section>

  <section style="padding: 80px 0; background: var(--cream);">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Common Questions</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--agate);">Pawnee County Jail Bail FAQ</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>How do I bail someone out of Pawnee County Jail?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Call Angel Bail Bonds at (405) 614-3000. Provide the inmate's name and charges. We post bonds at Pawnee County Jail and only charge the 10% premium required by Oklahoma law. Payment plans available.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>What are Pawnee County Jail's visitation hours?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Monday through Friday 7:30 AM to 9:00 PM, Saturday and Sunday 7:30 AM to 2:30 PM. Visits must be scheduled in advance through the sheriff's office online portal or by calling the jail.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--agate);"><span>How do I send mail to an inmate at Pawnee County Jail?</span><span>▼</span></summary><p style="color: var(--charcoal); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Address mail to: Inmate's Full Name & ID Number, Pawnee County Jail, 500 Harrison Street, Pawnee, OK 74058. All mail is subject to inspection.</p></details>
      </div>
    </div>
  </section>

  <section style="background: linear-gradient(135deg, #1a6b6a 0%, #145453 100%); padding: 80px 0;" class="text-cream">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="section-label" style="color: var(--gold);">Available 24/7</p>
      <h2 class="font-display text-3xl md:text-4xl mb-6">Someone in Pawnee County Jail?</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">Angel Bail Bonds serves Pawnee County from Stillwater. We know the process and can get your loved one out fast.</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.3rem; padding: 16px 40px;">(405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
