---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Pawnee County Jail',
  url: 'https://stillwaterokbailbonds.com/pawnee-county-jail-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/pawnee-county-jail-bail-bonds#business',
  description: 'Bail bond services for Pawnee County Jail at 500 Harrison St, Pawnee, OK. 24/7 availability from Stillwater.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: { '@type': 'PostalAddress', streetAddress: '500 Harrison St', addressLocality: 'Pawnee', addressRegion: 'OK', postalCode: '74058', addressCountry: 'US' },
  geo: { '@type': 'GeoCoordinates', latitude: 36.3376, longitude: -96.8039 },
  areaServed: { '@type': 'AdministrativeArea', name: 'Pawnee County, Oklahoma' },
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'How do I bail someone out of Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Pawnee County from Stillwater and can post bonds at the Pawnee County Jail at 500 Harrison St. We offer competitive rates and handle all paperwork.' } },
  { '@type': 'Question', name: 'What is the phone number for Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Pawnee County Jail can be reached at (918) 762-2565. The fax number is (918) 762-6407. The jail is located at 500 Harrison Street, Pawnee, OK 74058.' } },
  { '@type': 'Question', name: 'What are visitation hours at Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Visitation hours at Pawnee County Jail are Monday-Friday 7:30 AM to 9:00 PM and Saturday-Sunday 7:30 AM to 2:30 PM. Contact the jail to schedule visits in advance.' } },
  { '@type': 'Question', name: 'How much does bail cost at Pawnee County Jail?', acceptedAnswer: { '@type': 'Answer', text: 'Bail amounts vary by charge. Call the jail at (918) 762-2565 for the specific bail amount. When using Angel Bail Bonds, we offer competitive rates. Contact us to discuss pricing.' } }
] };

const howToData = { '@context': 'https://schema.org', '@type': 'HowTo',
  name: 'How to Bail Someone Out of Pawnee County Jail',
  description: 'Step-by-step guide to posting bail at Pawnee County Jail in Pawnee, Oklahoma.',
  step: [
    { '@type': 'HowToStep', name: 'Get inmate details', text: 'Call Pawnee County Jail at (918) 762-2565 for inmate info and bail amount.' },
    { '@type': 'HowToStep', name: 'Call Angel Bail Bonds', text: 'Call (405) 614-3000. We serve Pawnee County and can post bonds at the jail.' },
    { '@type': 'HowToStep', name: 'Pay premium and sign', text: 'Sign the agreement and pay the premium. Competitive rates available.' },
    { '@type': 'HowToStep', name: 'Bond posted and release', text: 'We post the bond and the jail processes the release.' }
  ]
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Pawnee County Bail Bonds', item: 'https://stillwaterokbailbonds.com/pawnee-county-bail-bonds' },
    { '@type': 'ListItem', position: 3, name: 'Pawnee County Jail', item: 'https://stillwaterokbailbonds.com/pawnee-county-jail-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Pawnee County Jail Bail Bonds | 500 Harrison St, Pawnee OK"
  description="Need bail bonds for Pawnee County Jail in Pawnee, Oklahoma? Angel Bail Bonds serves Pawnee County 24/7. Fast processing, competitive rates. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
