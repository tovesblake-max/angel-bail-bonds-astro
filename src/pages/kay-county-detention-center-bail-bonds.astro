---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Kay County Detention Center',
  url: 'https://stillwaterokbailbonds.com/kay-county-detention-center-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/kay-county-detention-center-bail-bonds#business',
  description: 'Bail bond services for Kay County Detention Center at 1101 W Dry Rd, Newkirk, OK. Available 24/7 from Stillwater.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1101 W Dry Rd',
    addressLocality: 'Newkirk',
    addressRegion: 'OK',
    postalCode: '74647',
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: 36.8670, longitude: -97.0531 },
  areaServed: { '@type': 'AdministrativeArea', name: 'Kay County, Oklahoma' },
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I bail someone out of Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Kay County from Stillwater and can post bonds at the detention center in Newkirk. You pay 10% of the bail amount. Payment plans are available.' } },
    { '@type': 'Question', name: 'What is the phone number for Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Kay County Detention Center can be reached at (580) 362-3393. The facility is located at 1101 W Dry Rd, Newkirk, OK 74647.' } },
    { '@type': 'Question', name: 'What are visitation hours at Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Visitation at Kay County Detention Center is Monday through Friday 7:30 AM to 9:00 PM and Saturday through Sunday 7:30 AM to 2:30 PM. Visits must be scheduled in advance. A valid government-issued photo ID is required.' } },
    { '@type': 'Question', name: 'How far is Kay County Detention Center from Stillwater?', acceptedAnswer: { '@type': 'Answer', text: 'Kay County Detention Center in Newkirk is about 90 minutes northwest of Stillwater. Angel Bail Bonds serves this facility regularly and can coordinate bond posting remotely or in person.' } }
  ]
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Kay County Bail Bonds', item: 'https://stillwaterokbailbonds.com/kay-county-bail-bonds' },
    { '@type': 'ListItem', position: 3, name: 'Kay County Detention Center', item: 'https://stillwaterokbailbonds.com/kay-county-detention-center-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Kay County Detention Center Bail Bonds Newkirk OK | 24/7 Service"
  description="Need bail bonds for Kay County Detention Center at 1101 W Dry Rd, Newkirk OK? Angel Bail Bonds serves Kay County 24/7. Fast processing, payment plans. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Kay County Detention Center — Newkirk, OK</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Kay County Detention Center</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">1101 W Dry Rd, Newkirk, OK 74647 · Served 24/7 from Stillwater</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Facility Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="https://www.google.com/maps/search/?api=1&query=1101+W+Dry+Rd+Newkirk+OK+74647" target="_blank" rel="noopener" style="color: var(--blue); text-decoration: none;">1101 W Dry Rd, Newkirk, OK 74647</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+15803623393" style="color: var(--blue); text-decoration: none;">(580) 362-3393</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td>
            <td style="padding: 10px 0; color: var(--slate-700);">M-F 7:30a–9p · Sat-Sun 7:30a–2:30p</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">10% premium · Payment plans available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Bail Out -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Bail Someone Out</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Get bail amount</strong><br><span style="color: var(--slate-500);">Call the facility at (580) 362-3393</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call us 24/7</strong><br><span style="color: var(--slate-500);">Angel Bail Bonds: (405) 614-3000</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay 10% &amp; sign</strong><br><span style="color: var(--slate-500);">Cash, cards, or payment plan</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">Bond posted, we keep you updated</span></div>
          </li>
        </ol>
      </div>
    </div>

    <!-- Responsive: stack columns on mobile -->
    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I bail someone out of Kay County Detention Center?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000. We post bonds at Kay County Detention Center in Newkirk and only charge the 10% premium required by Oklahoma law. Payment plans available.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What are visitation hours at Kay County Detention Center?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Monday–Friday 7:30 AM to 9:00 PM, Saturday–Sunday 7:30 AM to 2:30 PM. Schedule visits in advance and bring a valid government-issued photo ID.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How far is it from Stillwater?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">About 90 minutes northwest. Angel Bail Bonds serves this facility regularly and can coordinate bond posting remotely or in person.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What payment methods do you accept?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Cash, Visa, Mastercard, Zelle, Venmo. We also offer flexible payment plans so finances don't delay getting your loved one released.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/kay-county-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Kay County Bail Bonds →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Someone in Kay County Detention Center?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">24/7 availability · Payment plans · Serve all of Kay County</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
