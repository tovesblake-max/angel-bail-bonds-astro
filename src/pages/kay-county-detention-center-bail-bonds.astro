---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org', '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Kay County Detention Center',
  description: 'Bail bond services for Kay County Detention Center at 1101 W Dry Rd, Newkirk, OK. Available 24/7 from Stillwater.',
  image: '/images/logo.webp', telephone: '(405) 614-3000',
  address: { '@type': 'PostalAddress', streetAddress: '1101 W Dry Rd', addressLocality: 'Newkirk', addressRegion: 'OK', postalCode: '74647', addressCountry: 'US' },
  areaServed: { '@type': 'AdministrativeArea', name: 'Kay County, Oklahoma' },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '127' },
  openingHoursSpecification: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '00:00', closes: '23:59' }
};

const faqData = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'How do I bail someone out of Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Kay County from Stillwater and can post bonds at the detention center in Newkirk. You pay 10% of the bail amount. Payment plans are available.' } },
  { '@type': 'Question', name: 'What is the phone number for Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Kay County Detention Center can be reached at (580) 362-3393. The facility is located at 1101 W Dry Rd, Newkirk, OK 74647.' } },
  { '@type': 'Question', name: 'What are visitation hours at Kay County Detention Center?', acceptedAnswer: { '@type': 'Answer', text: 'Visitation at Kay County Detention Center is Monday through Friday 7:30 AM to 9:00 PM and Saturday through Sunday 7:30 AM to 2:30 PM. Visits must be scheduled in advance. A valid government-issued photo ID is required.' } },
  { '@type': 'Question', name: 'How far is Kay County Detention Center from Stillwater?', acceptedAnswer: { '@type': 'Answer', text: 'Kay County Detention Center in Newkirk is about 90 minutes northwest of Stillwater. Angel Bail Bonds serves this facility regularly and can coordinate bond posting remotely or in person.' } }
] };

const howToData = { '@context': 'https://schema.org', '@type': 'HowTo',
  name: 'How to Bail Someone Out of Kay County Detention Center in Newkirk, OK',
  description: 'Complete guide to posting bail at Kay County Detention Center in Newkirk, Oklahoma.',
  step: [
    { '@type': 'HowToStep', name: 'Get inmate info', text: 'Call Kay County Detention Center at (580) 362-3393 for inmate information and bail amount.' },
    { '@type': 'HowToStep', name: 'Call Angel Bail Bonds', text: 'Call (405) 614-3000 any time 24/7. We serve Kay County from Stillwater.' },
    { '@type': 'HowToStep', name: 'Pay 10% premium', text: 'Sign the bond agreement and pay 10% of the bail amount. Payment plans available.' },
    { '@type': 'HowToStep', name: 'Release', text: 'Bond posted at Kay County Detention Center and the release process begins.' }
  ]
};
---

<BaseLayout
  title="Kay County Detention Center Bail Bonds Newkirk OK | 24/7 Service"
  description="Need bail bonds for Kay County Detention Center at 1101 W Dry Rd, Newkirk OK? Angel Bail Bonds serves Kay County 24/7. Fast processing, payment plans. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />

  <section style="background: var(--navy-deep); min-height: 50vh;" class="flex items-center text-white">
    <div class="max-w-7xl mx-auto px-4 py-20 w-full">
      <p class="section-label" style="color: white; opacity: 0.9;">Kay County Detention Center — Newkirk, OK</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mb-4 text-white">Bail Bonds for<br><span>Kay County Detention Center</span></h1>
      <p class="text-lg md:text-xl max-w-2xl mb-8 opacity-90 text-white">1101 W Dry Road, Newkirk, OK 74647 — Angel Bail Bonds serves Kay County from Stillwater with 24/7 availability.</p>
      <a href="tel:+14056143000" class="btn-primary"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>(405) 614-3000</a>
    </div>
  </section>

  <section style="background: var(--slate-50); padding: 80px 0;">
    <div class="max-w-7xl mx-auto px-4">
      <p class="section-label">Facility Details</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--slate-900);">Kay County Detention Center Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card reveal"><div class="icon-box">📍</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--slate-900);">Address</h3><p style="color: var(--slate-500); opacity: 0.8; font-size: 0.95rem;"><a href="https://www.google.com/maps/search/?api=1&query=1101+W+Dry+Rd+Newkirk+OK+74647" target="_blank" rel="noopener" style="color: var(--blue); text-decoration: none; cursor: pointer;">1101 W Dry Road<br>Newkirk, OK 74647</a></p></div>
        <div class="card reveal reveal-delay-1"><div class="icon-box">📞</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--slate-900);">Phone</h3><p style="color: var(--slate-500); opacity: 0.8; font-size: 0.95rem;"><a href="tel:+15803623393" style="color: var(--blue); text-decoration: none;">(580) 362-3393</a></p></div>
        <div class="card reveal reveal-delay-2"><div class="icon-box">⏰</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--slate-900);">Visitation Hours</h3><p style="color: var(--slate-500); opacity: 0.8; font-size: 0.95rem;">M-F: 7:30am - 9:00pm<br>Sat-Sun: 7:30am - 2:30pm</p></div>
        <div class="card reveal reveal-delay-3"><div class="icon-box">💰</div><h3 class="font-semibold mt-4 mb-2" style="color: var(--slate-900);">Bail Info</h3><p style="color: var(--slate-500); opacity: 0.8; font-size: 0.95rem;">10% premium<br>Payment plans available</p></div>
      </div>
    </div>
  </section>

  <section style="padding: 100px 0; background: white;">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Step-by-Step Guide</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--slate-900);">How to Bail Someone Out of Kay County Detention Center</h2>
      <p style="color: var(--slate-500); opacity: 0.8; margin-bottom: 48px; font-size: 1.1rem;">Kay County Detention Center in Newkirk is about 90 minutes northwest of Stillwater. We serve this facility and can post bonds quickly.</p>
      <div style="display: flex; flex-direction: column; gap: 32px;">
        <div class="reveal" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">1</div><div><h3 class="font-display text-xl mb-2" style="color: var(--slate-900);">Get the Bail Amount</h3><p style="color: var(--slate-500); opacity: 0.8;">Call Kay County Detention Center at <strong>(580) 362-3393</strong> for the inmate's bail amount, charges, and booking details. Have their full name ready.</p></div></div>
        <div class="reveal reveal-delay-1" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">2</div><div><h3 class="font-display text-xl mb-2" style="color: var(--slate-900);">Call Angel Bail Bonds</h3><p style="color: var(--slate-500); opacity: 0.8;">Call <strong>(405) 614-3000</strong> — available 24/7. We'll confirm the details, explain the 10% premium, and discuss payment plan options.</p></div></div>
        <div class="reveal reveal-delay-2" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">3</div><div><h3 class="font-display text-xl mb-2" style="color: var(--slate-900);">Sign Bond & Pay 10% Premium</h3><p style="color: var(--slate-500); opacity: 0.8;">Complete the bond agreement and pay 10% of the bail amount. We accept cash, credit cards, and offer flexible payment plans.</p></div></div>
        <div class="reveal reveal-delay-3" style="display: flex; gap: 20px;"><div style="min-width: 48px; height: 48px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">4</div><div><h3 class="font-display text-xl mb-2" style="color: var(--slate-900);">Bond Posted — Release Begins</h3><p style="color: var(--slate-500); opacity: 0.8;">We post the bond at Kay County Detention Center and the release process starts. We'll keep you updated throughout.</p></div></div>
      </div>
    </div>
  </section>

  <section style="padding: 80px 0; background: var(--slate-50);">
    <div class="max-w-4xl mx-auto px-4">
      <p class="section-label">Common Questions</p>
      <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--slate-900);">Kay County Detention Center Bail FAQ</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--slate-900);"><span>How do I bail someone out of Kay County Detention Center?</span><span>▼</span></summary><p style="color: var(--slate-500); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Call Angel Bail Bonds at (405) 614-3000. We post bonds at Kay County Detention Center in Newkirk and only charge the 10% premium required by Oklahoma law. Payment plans available.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--slate-900);"><span>What are visitation hours at Kay County Detention Center?</span><span>▼</span></summary><p style="color: var(--slate-500); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Monday through Friday 7:30 AM to 9:00 PM, Saturday and Sunday 7:30 AM to 2:30 PM. Schedule visits in advance and bring a valid government-issued photo ID.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--slate-900);"><span>How far is Kay County Detention Center from Stillwater?</span><span>▼</span></summary><p style="color: var(--slate-500); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">Kay County Detention Center in Newkirk is about 90 minutes northwest of Stillwater. Angel Bail Bonds serves this facility regularly and can coordinate bond posting remotely or in person.</p></details>
        <details class="card" style="background: white; cursor: pointer;"><summary class="flex justify-between items-center font-semibold" style="color: var(--slate-900);"><span>What forms of payment do you accept for Kay County bonds?</span><span>▼</span></summary><p style="color: var(--slate-500); opacity: 0.8; margin-top: 16px; padding-top: 16px; border-top: 1px solid #eee;">We accept cash, credit cards, and debit cards. We also offer flexible payment plans so finances don't delay getting your loved one released. The standard bail bond premium in Oklahoma is 10% of the total bail amount.</p></details>
      </div>
    </div>
  </section>

  <section style="background: var(--navy-deep); padding: 80px 0;" class="text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="section-label" style="color: white; opacity: 0.9;">Available 24/7</p>
      <h2 class="font-display text-3xl md:text-4xl mb-6 text-white">Someone in Kay County Detention Center?</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90 text-white">Angel Bail Bonds serves Kay County from Stillwater. Fast processing, payment plans, and 24/7 availability.</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.3rem; padding: 16px 40px;">(405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
