---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds - Lincoln County Jail',
  url: 'https://stillwaterokbailbonds.com/lincoln-county-jail-chandler-bail-bonds',
  '@id': 'https://stillwaterokbailbonds.com/lincoln-county-jail-chandler-bail-bonds#business',
  description: 'Bail bond services for Lincoln County Jail at 811 Manvel Ave, Chandler, OK. Available 24/7 from Stillwater.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '811 Manvel Ave #14',
    addressLocality: 'Chandler',
    addressRegion: 'OK',
    postalCode: '74834',
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: 35.7012, longitude: -96.8808 },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Lincoln County, Oklahoma'
  },
  sameAs: ['https://g.co/kgs/Angel-Bail-Bonds-Stillwater'],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127'
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '00:00',
    closes: '23:59'
  }
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I bail someone out of Lincoln County Jail in Chandler?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call Angel Bail Bonds at (405) 614-3000. We serve Lincoln County and can post bonds at the jail in Chandler. We offer competitive rates. Contact us to discuss pricing.'
      }
    },
    {
      '@type': 'Question',
      name: 'What is Lincoln County Jail\'s phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lincoln County Jail in Chandler can be reached at (405) 258-1191 ext 294. Call for inmate information, bail amounts, and booking details.'
      }
    },
    {
      '@type': 'Question',
      name: 'What are visitation hours at Lincoln County Jail?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'On-site visitation at Lincoln County Jail is Monday through Friday, 10:00 AM to 3:00 PM. Call (405) 258-1191 to schedule visits in advance. A government-issued photo ID is required.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I use property as bail collateral at Lincoln County?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, Lincoln County accepts property bonds using county property as collateral. Contact the jail at (405) 258-1191 for property bond requirements. Note that property bonds take longer to process than using a bail bondsman.'
      }
    }
  ]
};

const howToData = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Bail Someone Out of Lincoln County Jail in Chandler, OK',
  description: 'Complete guide to posting bail at Lincoln County Jail in Chandler, Oklahoma.',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Get inmate info',
      text: 'Call Lincoln County Jail at (405) 258-1191 or search the inmate roster at lincolncountysheriffok.gov.'
    },
    {
      '@type': 'HowToStep',
      name: 'Call Angel Bail Bonds',
      text: 'Call (405) 614-3000 any time 24/7.'
    },
    {
      '@type': 'HowToStep',
      name: 'Pay premium and sign',
      text: 'Sign the bond and pay the premium. Competitive rates available.'
    },
    {
      '@type': 'HowToStep',
      name: 'Release',
      text: 'Bond posted at Lincoln County Jail, release process begins.'
    }
  ]
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://stillwaterokbailbonds.com/' },
    { '@type': 'ListItem', position: 2, name: 'Lincoln County Bail Bonds', item: 'https://stillwaterokbailbonds.com/lincoln-county-bail-bonds' },
    { '@type': 'ListItem', position: 3, name: 'Lincoln County Jail', item: 'https://stillwaterokbailbonds.com/lincoln-county-jail-chandler-bail-bonds' }
  ]
};
---

<BaseLayout
  title="Lincoln County Jail Bail Bonds Chandler OK | 24/7 Service"
  description="Need bail bonds for Lincoln County Jail at 811 Manvel Ave, Chandler OK? Angel Bail Bonds serves Lincoln County 24/7. Fast processing, competitive rates. Call (405) 614-3000."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <!-- HERO — compact -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%); padding: 56px 1.5rem 48px;">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;">Lincoln County Jail — Chandler, OK</p>
      <h1 style="color: white; font-size: clamp(1.6rem, 4vw, 2.4rem); line-height: 1.2; margin-bottom: 10px;">Bail Bonds for Lincoln County Jail</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem; margin-bottom: 20px;">811 Manvel Ave, Chandler, OK 74834 · Served 24/7 from Stillwater</p>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px;">📞 (405) 614-3000</a>
    </div>
  </section>

  <!-- FACILITY + STEPS — combined, two-column -->
  <section style="padding: 48px 1.5rem; background: white;">
    <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">

      <!-- Left: Facility Details -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Facility Details</h2>
        <table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600; width: 100px;">Address</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="https://www.google.com/maps/search/?api=1&query=811+Manvel+Ave+Chandler+OK+74834" target="_blank" rel="noopener" style="color: var(--blue); text-decoration: none;">811 Manvel Ave #14, Chandler, OK 74834</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Phone</td>
            <td style="padding: 10px 0; color: var(--slate-700);"><a href="tel:+14052581191" style="color: var(--blue); text-decoration: none;">(405) 258-1191 ext 294</a></td>
          </tr>
          <tr style="border-bottom: 1px solid var(--slate-100);">
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Visitation</td>
            <td style="padding: 10px 0; color: var(--slate-700);">M-F 10:00am–3:00pm · Schedule in advance</td>
          </tr>
          <tr>
            <td style="padding: 10px 0; color: var(--slate-400); font-weight: 600;">Bond Cost</td>
            <td style="padding: 10px 0; color: var(--slate-700);">Competitive rates available</td>
          </tr>
        </table>
      </div>

      <!-- Right: How to Bail Out -->
      <div>
        <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">How to Bail Someone Out</h2>
        <ol style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
            <div><strong style="color: var(--slate-800);">Get bail amount</strong><br><span style="color: var(--slate-500);">Call (405) 258-1191 ext 294</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
            <div><strong style="color: var(--slate-800);">Call us 24/7</strong><br><span style="color: var(--slate-500);">Angel Bail Bonds: (405) 614-3000</span></div>
          </li>
          <li style="display: flex; gap: 12px; margin-bottom: 14px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
            <div><strong style="color: var(--slate-800);">Pay premium &amp; sign</strong><br><span style="color: var(--slate-500);">Cash, cards accepted</span></div>
          </li>
          <li style="display: flex; gap: 12px;">
            <span style="min-width: 28px; height: 28px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">✓</span>
            <div><strong style="color: var(--slate-800);">Release begins</strong><br><span style="color: var(--slate-500);">We keep you updated</span></div>
          </li>
        </ol>
      </div>
    </div>

    <style>
      @media (max-width: 640px) {
        section div[style*="grid-template-columns: 1fr 1fr"] {
          grid-template-columns: 1fr !important;
          gap: 32px !important;
        }
      }
    </style>
  </section>

  <!-- FAQ — compact accordion -->
  <section style="padding: 40px 1.5rem; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="color: var(--navy); font-size: 1.15rem; font-weight: 700; margin-bottom: 16px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">How do I bail someone out of Lincoln County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Call Angel Bail Bonds at (405) 614-3000. We post bonds at Lincoln County Jail in Chandler and offer competitive rates. Contact us to discuss pricing for your situation.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">What are visitation hours at Lincoln County Jail?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Monday through Friday, 10:00 AM to 3:00 PM. Call (405) 258-1191 to schedule visits in advance. Bring a government-issued photo ID.</p>
        </details>
        <details style="background: white; border-radius: 8px; padding: 14px 18px; cursor: pointer; border: 1px solid var(--slate-100);">
          <summary style="font-weight: 600; font-size: 0.9rem; color: var(--slate-800);">Can I use property as bail collateral at Lincoln County?</summary>
          <p style="color: var(--slate-500); margin-top: 10px; font-size: 0.85rem; line-height: 1.6;">Yes, Lincoln County accepts property bonds using county property as collateral. Contact the jail at (405) 258-1191 for property bond requirements. Note that property bonds take longer to process than using a bail bondsman.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Pages -->
  <section style="padding: 24px 1.5rem 0; background: var(--slate-50);">
    <div style="max-width: 900px; margin: 0 auto;">
      <p style="font-size: 0.8rem; color: var(--slate-400); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Also Serving</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/lincoln-county-bail-bonds" style="font-size: 0.85rem; color: var(--blue); text-decoration: none; padding: 6px 14px; background: white; border: 1px solid var(--slate-100); border-radius: 6px;">Lincoln County Bail Bonds →</a>
      </div>
    </div>
  </section>

  <!-- CTA BAR — tight -->
  <section style="background: var(--navy-deep); padding: 36px 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
      <div>
        <p style="color: white; font-size: 1.1rem; font-weight: 700; margin-bottom: 2px;">Someone in Lincoln County Jail?</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">24/7 availability · Competitive rates · About 1 hour south of Stillwater</p>
      </div>
      <a href="tel:+14056143000" class="btn-primary" style="font-size: 1rem; padding: 12px 28px; white-space: nowrap;">📞 (405) 614-3000</a>
    </div>
  </section>
</BaseLayout>
