---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  { q: 'How much does a bail bond cost?', a: 'In Oklahoma, we offer competitive rates on bail bonds. The premium is non-refundable and is the fee for the bail bond service. Contact us to discuss pricing for your specific situation.' },
  { q: 'What do I need to bail someone out of jail?', a: 'You\'ll need the full legal name of the person in custody, their date of birth, the jail or facility where they\'re being held, and the charges if you know them. We\'ll verify everything else directly with the jail. You\'ll also need a valid ID and the ability to sign paperwork — which can be done online, by phone, or in person.' },
  { q: 'How long does the bail process take?', a: 'Once paperwork is completed, most clients are released within 2-6 hours depending on the facility. Some jails process faster than others. We stay in contact with you throughout the entire process until your loved one walks out.' },
  { q: 'Do you offer competitive rates?', a: 'Yes. We understand bail is an unexpected expense. We offer competitive rates and accept Visa, Mastercard, cash, Zelle, and Venmo. Call us to discuss options that work for your situation.' },
  { q: 'Can I bail someone out online or over the phone?', a: 'Absolutely. The entire bail process can be completed remotely — by phone, email, or e-sign. You don\'t need to come to our office. We handle everything and keep you informed every step of the way.' },
  { q: 'What happens if they miss their court date?', a: 'If the defendant misses a court date, the bond may be forfeited and a warrant could be issued for their arrest. If this happens, contact us immediately. We can often help resolve the situation before it escalates.' },
  { q: 'Which jails do you serve in Central Oklahoma?', a: 'We serve Payne County Detention Center (Stillwater), Pawnee County Jail, Lincoln County Jail (Chandler), Kay County Detention Center (Newkirk), Noble County Jail (Perry), and Stillwater City Jail. We have deep relationships with staff at each facility.' },
  { q: 'Do I get my money back after the case is over?', a: 'The premium paid for the bail bond is non-refundable — it\'s the fee for the bail bond service. However, if you posted cash bail directly with the court (the full amount), that is returned after the case concludes, minus any court fees.' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://stillwaterokbailbonds.com/#business',
      url: 'https://stillwaterokbailbonds.com',
      name: 'Angel Bail Bonds',
      description: 'Professional bail bond services in Stillwater, Oklahoma. 15+ years of experience serving Central Oklahoma counties.',
      image: 'https://stillwaterokbailbonds.com/images/logo.webp',
      telephone: '(405) 614-3000',
      email: 'bailbondangel@gmail.com',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Stillwater',
        addressRegion: 'OK',
        addressCountry: 'US',
      },
      priceRange: '$$',
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '127',
      },
      areaServed: [
        'Payne County', 'Pawnee County', 'Lincoln County', 'Kay County', 'Noble County',
      ],
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
        opens: '00:00',
        closes: '23:59',
      },
      sameAs: [],
    },
  ],
};
---

<BaseLayout
  title="Bail Bonds in Stillwater, Oklahoma | Angel Bail Bonds 24/7"
  description="Angel Bail Bonds offers 24/7 professional bail bond services in Stillwater and Central Oklahoma. 15+ years experience, 4.9 stars, women-owned. Emergency bail bonds for Payne, Pawnee, Lincoln, Kay & Noble counties."
  structuredData={structuredData}
>

  <!-- ═══ SECTION 1/2: HERO ═══ -->
  <section style="background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 50%, #1e3a5f 100%); min-height: 90vh; display: flex; align-items: center; padding-top: 68px; position: relative; overflow: hidden;">
    <!-- Subtle radial overlay -->
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 20%, rgba(37,99,235,0.08) 0%, transparent 60%);"></div>
    <div class="max-w-6xl mx-auto px-5 sm:px-6 w-full relative" style="padding-top: 48px; padding-bottom: 48px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <!-- Availability Badge -->
          <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6" style="background: rgba(22,163,74,0.15); border: 1px solid rgba(22,163,74,0.3);">
            <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--green); display: inline-block; animation: pulse 2s infinite;"></span>
            <span style="color: rgba(255,255,255,0.9); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Open 24/7 — Holidays Included</span>
          </div>

          <!-- Headline -->
          <h1 class="reveal" style="color: white; margin-bottom: 1.25rem; font-size: clamp(2.25rem, 5vw, 3.25rem);">
            Get Your Loved One<br>Out of Jail. <span style="color: #60a5fa;">Fast.</span>
          </h1>

          <!-- Subheadline -->
          <p class="reveal" style="color: rgba(255,255,255,0.65); font-size: 1.15rem; line-height: 1.7; margin-bottom: 2rem; max-width: 520px;">
            Licensed agents available right now. Competitive rates. Most clients released within hours. Serving 5 Central Oklahoma counties for 15+ years.
          </p>

          <!-- CTAs -->
          <div class="reveal flex flex-col sm:flex-row gap-4" style="margin-bottom: 2.5rem;">
            <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.1rem; padding: 1rem 2.25rem;">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call Now: (405) 614-3000
            </a>
            <a href="/contact" class="btn-secondary" style="font-size: 1.05rem;">
              Get a Free Quote
            </a>
          </div>

          <!-- Hablamos Español -->
          <p class="reveal" style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">
            <a href="/es/" style="color: rgba(255,255,255,0.5); text-decoration: underline; text-underline-offset: 3px;">Hablamos Español</a>
          </p>
        </div>

        <!-- Stats Panel -->
        <div class="reveal" style="background: rgba(255,255,255,0.06); border-radius: var(--radius-lg); padding: 2.5rem; backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.1);">
          <div class="grid grid-cols-2 gap-8">
            <div style="text-align: center;">
              <p class="stat-number" style="color: white;">24/7</p>
              <p class="stat-label" style="color: rgba(255,255,255,0.5);">Always Available</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: white;">4.9<span style="font-size: 1.25rem; margin-left: 4px; color: var(--amber);">★</span></p>
              <p class="stat-label" style="color: rgba(255,255,255,0.5);">Google Rating</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: white;">15+</p>
              <p class="stat-label" style="color: rgba(255,255,255,0.5);">Years Experience</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: white;">5</p>
              <p class="stat-label" style="color: rgba(255,255,255,0.5);">Counties Served</p>
            </div>
          </div>
          <div style="margin-top: 1.75rem; padding-top: 1.75rem; border-top: 1px solid rgba(255,255,255,0.1); text-align: center;">
            <p style="color: rgba(255,255,255,0.45); font-size: 0.85rem;">Women-Owned &bull; Licensed &bull; Insured</p>
          </div>
        </div>
      </div>
    </div>
    <style>
      @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    </style>
  </section>

  <!-- ═══ SECTION 3: TRUST INDICATORS ═══ -->
  <section style="background: white; border-bottom: 1px solid var(--slate-200);">
    <div class="max-w-6xl mx-auto px-5 sm:px-6 py-5">
      <div class="trust-bar reveal">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>Licensed & Insured</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          <span>4.9 ★ Google Rating</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>15+ Years Experience</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--slate-500)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          <span>Competitive Rates Available</span>
        </div>
        <div class="payment-icons">
          <span class="payment-badge"><svg viewBox="0 0 48 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19.5 2.5l-3.2 11h-2.6l3.2-11h2.6zm13.1 7.1l1.4-3.8.8 3.8h-2.2zm2.9 3.9h2.4l-2.1-11h-2.2c-.5 0-.9.3-1.1.7l-3.8 10.3h2.7l.5-1.5h3.3l.3 1.5zm-6.7-3.6c0-2.9-4-3.1-4-4.4 0-.4.4-.8 1.2-.9.9-.1 2 .2 2.4.4l.4-2c-.5-.2-1.3-.4-2.2-.4-2.5 0-4.2 1.3-4.2 3.2 0 1.4 1.2 2.2 2.2 2.6 1 .5 1.3.8 1.3 1.2 0 .7-.8 1-1.5 1-.9 0-1.8-.2-2.5-.6l-.4 2c.6.3 1.6.4 2.7.4 2.6 0 4.3-1.3 4.6-3.5zm-10.3-7.4l-4.9 11h-2.7l-2.4-8.8c-.1-.6-.3-.7-.7-.9-.8-.4-2-.7-3.1-.9l.1-.4h4.3c.6 0 1 .4 1.1 1l1.1 5.6 2.6-6.6h2.6z" fill="currentColor"/></svg> Visa</span>
          <span class="payment-badge"><svg viewBox="0 0 48 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="18" cy="8" r="7" fill="#EB001B" opacity="0.8"/><circle cx="30" cy="8" r="7" fill="#F79E1B" opacity="0.8"/><path d="M24 2.4a7 7 0 0 1 2.6 5.6A7 7 0 0 1 24 13.6 7 7 0 0 1 21.4 8 7 7 0 0 1 24 2.4z" fill="#FF5F00" opacity="0.9"/></svg> MC</span>
          <span class="payment-badge"><svg viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1" y="2" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M1 6h18" stroke="currentColor" stroke-width="1.5"/><path d="M5 10h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> Cash</span>
          <span class="payment-badge"><svg viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 1L3 5v6l7 4 7-4V5l-7-4z" stroke="#6C1CD1" stroke-width="1.5" fill="none"/><path d="M10 5v6M7 6.5l3 2 3-2" stroke="#6C1CD1" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg> Zelle</span>
          <span class="payment-badge"><svg viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 1.5c-4.7 0-8.5 2.9-8.5 6.5s3.8 6.5 8.5 6.5 8.5-2.9 8.5-6.5-3.8-6.5-8.5-6.5z" fill="#008CFF" opacity="0.15"/><path d="M5 5.5l3 5 4-5" stroke="#008CFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 5.5l3 5" stroke="#008CFF" stroke-width="1.8" stroke-linecap="round"/></svg> Venmo</span>
          <span class="financing-badge">💰 Financing Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SECTION 4: HOW BAIL WORKS ═══ -->
  <section id="how-it-works" class="section-padding" style="background: var(--slate-50);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">How It Works</span>
        <h2 style="color: var(--slate-900); margin-bottom: 1rem;">The Bail Process — Simple & Fast</h2>
        <p style="color: var(--slate-500); font-size: 1.05rem; max-width: 560px; margin: 0 auto;">
          Most people have never bailed anyone out before. Here's exactly what happens when you call us.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        <div class="step-card card reveal reveal-delay-1">
          <div class="step-number">1</div>
          <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">Call Us</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">Reach a licensed bail agent 24/7. We answer fast — day or night.</p>
        </div>
        <div class="step-card card reveal reveal-delay-2">
          <div class="step-number">2</div>
          <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">We Gather Info</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">We verify charges, bond amount, and booking status with the jail.</p>
        </div>
        <div class="step-card card reveal reveal-delay-3">
          <div class="step-number">3</div>
          <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">Sign Paperwork</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">Complete forms online, by phone, email, or in person. E-sign available.</p>
        </div>
        <div class="step-card card reveal reveal-delay-4">
          <div class="step-number">4</div>
          <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">We Post Bail</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">We handle everything with the court and jail. Competitive rates available.</p>
        </div>
        <div class="step-card card reveal reveal-delay-5">
          <div class="step-number">5</div>
          <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;">Release</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; line-height: 1.6;">Your loved one is released. We stay in contact until they walk out.</p>
        </div>
      </div>

      <div class="text-center reveal" style="margin-top: 2.5rem;">
        <p style="color: var(--slate-500); font-size: 0.95rem; margin-bottom: 1rem;">The entire process can be done 100% remotely — from your phone.</p>
        <a href="tel:+14056143000" class="btn-primary">Start the Process Now</a>
      </div>
    </div>
  </section>

  <!-- ═══ SECTION 5: SERVICES / BOND TYPES ═══ -->
  <section id="services" class="section-padding" style="background: white;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Our Services</span>
        <h2 style="color: var(--slate-900); margin-bottom: 1rem;">Bail Bond Services for Every Situation</h2>
        <p style="color: var(--slate-500); font-size: 1.05rem; max-width: 560px; margin: 0 auto;">
          No matter the charge, we handle it with speed, discretion, and professionalism.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card reveal reveal-delay-1">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">⚖️</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Felony Bail Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Experienced handling of serious charges requiring substantial bail amounts.</p>
        </div>
        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">📋</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Misdemeanor Bail Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Quick processing for less serious charges with competitive rates.</p>
        </div>
        <div class="card reveal reveal-delay-3" style="border-color: var(--red); border-width: 2px;">
          <div class="icon-box" style="background: rgba(220,38,38,0.08); color: var(--red); margin-bottom: 1rem;">🚗</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">DUI / DWI Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Specialized experience with impaired driving charges. High-volume — we know the process inside and out.</p>
        </div>
        <div class="card reveal reveal-delay-1" style="border-color: var(--red); border-width: 2px;">
          <div class="icon-box" style="background: rgba(220,38,38,0.08); color: var(--red); margin-bottom: 1rem;">🛡️</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Domestic Violence Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Confidential handling of sensitive family matters with protective conditions.</p>
        </div>
        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">💊</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Drug Charge Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Expert assistance with possession and related charges across all Oklahoma counties.</p>
        </div>
        <div class="card reveal reveal-delay-3">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">📱</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Bail From Home</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Complete the entire bail process from your phone or computer. No office visit required.</p>
        </div>
      </div>

      <div class="text-center reveal" style="margin-top: 3rem;">
        <a href="/services" class="btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ═══ SECTION 6: AREAS WE SERVE ═══ -->
  <section id="areas" class="section-padding" style="background: var(--slate-50);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Where We Serve</span>
        <h2 style="color: var(--slate-900); margin-bottom: 1rem;">5 Central Oklahoma Counties</h2>
        <p style="color: var(--slate-500); font-size: 1.05rem; max-width: 560px; margin: 0 auto;">
          Deep local knowledge and relationships with every jail and courthouse we serve.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        <a href="/payne-county-detention-center-bail-bonds" class="jail-info-card reveal reveal-delay-1" style="text-decoration: none;">
          <h3 style="color: var(--navy); font-size: 1.05rem; font-weight: 700; margin-bottom: 0.375rem;">Payne County Detention Center</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; margin-bottom: 0.5rem;">606 S Husband St, Stillwater, OK</p>
          <p style="color: var(--blue); font-size: 0.8rem; font-weight: 600;">View Jail Info & Inmate Search →</p>
        </a>
        <a href="/pawnee-county-jail-bail-bonds" class="jail-info-card reveal reveal-delay-2" style="text-decoration: none;">
          <h3 style="color: var(--navy); font-size: 1.05rem; font-weight: 700; margin-bottom: 0.375rem;">Pawnee County Jail</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; margin-bottom: 0.5rem;">500 Harrison St, Pawnee, OK</p>
          <p style="color: var(--blue); font-size: 0.8rem; font-weight: 600;">View Jail Info & Inmate Search →</p>
        </a>
        <a href="/lincoln-county-jail-chandler-bail-bonds" class="jail-info-card reveal reveal-delay-3" style="text-decoration: none;">
          <h3 style="color: var(--navy); font-size: 1.05rem; font-weight: 700; margin-bottom: 0.375rem;">Lincoln County Jail</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; margin-bottom: 0.5rem;">811 Manvel Ave #14, Chandler, OK</p>
          <p style="color: var(--blue); font-size: 0.8rem; font-weight: 600;">View Jail Info & Inmate Search →</p>
        </a>
        <a href="/kay-county-detention-center-bail-bonds" class="jail-info-card reveal reveal-delay-1" style="text-decoration: none;">
          <h3 style="color: var(--navy); font-size: 1.05rem; font-weight: 700; margin-bottom: 0.375rem;">Kay County Detention Center</h3>
          <p style="color: var(--slate-500); font-size: 0.85rem; margin-bottom: 0.5rem;">1101 W Dry Rd, Newkirk, OK</p>
          <p style="color: var(--blue); font-size: 0.8rem; font-weight: 600;">View Jail Info & Inmate Search →</p>
        </a>
