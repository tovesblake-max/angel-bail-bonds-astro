          <p style="color: var(--slate-400); font-size: 0.8rem;">Stillwater</p>
        </a>
      </div>

      <div class="reveal" style="background: white; border-radius: var(--radius-lg); padding: 2rem 2.5rem; text-align: center; border: 1px solid var(--slate-200); box-shadow: var(--shadow-sm);">
        <h3 style="color: var(--navy); font-size: 1.25rem; margin-bottom: 0.75rem;">Payne County Jail Specialist</h3>
        <p style="color: var(--slate-500); max-width: 500px; margin: 0 auto 1.25rem; font-size: 0.95rem;">
