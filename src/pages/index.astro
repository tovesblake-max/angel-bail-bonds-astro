---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds',
  description: 'Professional bail bond services in Stillwater, Oklahoma. 15+ years of experience serving Central Oklahoma counties.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  email: 'bailbondangel@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Stillwater',
    addressRegion: 'OK',
    addressCountry: 'US',
  },
  priceRange: '$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '27',
  },
  areaServed: [
    'Payne County',
    'Pawnee County',
    'Lincoln County',
    'Kay County',
    'Noble County',
  ],
};
---

<BaseLayout
  title="Bail Bonds in Stillwater, Oklahoma"
  description="Angel Bail Bonds offers 24/7 professional bail bond services in Stillwater and Central Oklahoma. 15+ years experience, 5.0 stars, women-owned. Emergency bail bonds for Payne, Pawnee, Lincoln, Kay & Noble counties."
  ogImage="/images/hero-agate.webp"
  structuredData={structuredData}
>
  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden" style="background: linear-gradient(160deg, #0f4a4a 0%, #1a6b6a 40%, #1d7574 100%); min-height: 92vh;">
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: url('/images/agate-dark.webp'); background-size: cover; background-position: center;"></div>
    <!-- Gradient overlay for depth -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 70% 20%, rgba(201,168,76,0.08) 0%, transparent 60%);"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-5 sm:px-6 flex flex-col justify-center" style="min-height: 92vh; padding-top: 72px;">
      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-8" style="background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.25);">
          <span class="w-2 h-2 rounded-full bg-gold animate-pulse"></span>
          <span class="text-gold text-xs font-semibold tracking-wide uppercase">Available 24/7 — Call Anytime</span>
        </div>

        <!-- Headline -->
        <h1 class="reveal text-cream mb-6" style="font-size: clamp(2.75rem, 5.5vw, 4.25rem); line-height: 1.08; letter-spacing: -0.025em;">
          Professional Bail Bonds in <span class="text-gold">Stillwater</span> & Central Oklahoma
        </h1>

        <!-- Subheadline -->
        <p class="reveal text-cream/70 text-lg md:text-xl mb-10 max-w-xl leading-relaxed">
          Fast, confidential, and compassionate bail bond services. Trusted by families across 5 Oklahoma counties for over 15 years.
        </p>

        <!-- CTAs -->
        <div class="reveal flex flex-col sm:flex-row gap-4">
          <a href="tel:+14056143000" class="btn-primary text-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call Now: (405) 614-3000
          </a>
          <a href="/how-bail-works" class="btn-secondary text-base">
            Learn How Bail Works
          </a>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="reveal mt-auto mb-10 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 pt-12 border-t border-cream/10" style="max-width: 720px;">
        <div>
          <p class="stat-number text-gold">24/7</p>
          <p class="stat-label">Always Available</p>
        </div>
        <div>
          <p class="stat-number text-gold">5.0<span class="text-xl ml-1">★</span></p>
          <p class="stat-label">Google Rating</p>
        </div>
        <div>
          <p class="stat-number text-gold">15+</p>
          <p class="stat-label">Years Experience</p>
        </div>
        <div>
          <p class="stat-number text-gold">5</p>
          <p class="stat-label">Counties Served</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section id="services" class="section-padding bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">What We Do</span>
        <h2 class="text-agate mb-4">Bail Bond Services</h2>
        <p class="text-secondary text-lg max-w-xl mx-auto">
          We handle all types of bail situations with discretion, speed, and professionalism.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card reveal reveal-delay-1">
          <div class="icon-box icon-box-agate mb-4">⚖️</div>
          <h3 class="text-agate text-lg mb-2">Felony Bail Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Experienced handling of serious charges requiring substantial bail amounts.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-agate mb-4">📋</div>
          <h3 class="text-agate text-lg mb-2">Misdemeanor Bail Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Quick processing for less serious charges with flexible payment options.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="icon-box icon-box-agate mb-4">🚗</div>
          <h3 class="text-agate text-lg mb-2">DUI/DWI Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Specialized experience with impaired driving charges across Oklahoma counties.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-1">
          <div class="icon-box icon-box-agate mb-4">🛡️</div>
          <h3 class="text-agate text-lg mb-2">Domestic Violence Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Confidential handling of sensitive family matters with protective conditions.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-agate mb-4">💊</div>
          <h3 class="text-agate text-lg mb-2">Drug Charges Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Expert assistance with possession and trafficking charges.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="icon-box icon-box-agate mb-4">📄</div>
          <h3 class="text-agate text-lg mb-2">Traffic & Warrant Bonds</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">Fast resolution for traffic violations and outstanding warrant issues.</p>
          <p class="text-gold font-semibold text-sm">10% Premium</p>
        </div>
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/services" class="btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICE AREAS ═══ -->
  <section class="section-padding bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Where We Serve</span>
        <h2 class="text-agate mb-4">5 Central Oklahoma Counties</h2>
        <p class="text-secondary text-lg max-w-xl mx-auto">
          Serving families and communities across Central Oklahoma with local knowledge and fast response times.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-10">
        <a href="/payne-county-jail-bail-bonds" class="reveal reveal-delay-1 group text-center p-6 rounded-xl bg-white border border-transparent hover:border-gold/30 transition-all" style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">
          <p class="text-3xl mb-2">🏛️</p>
          <h3 class="text-agate text-base font-bold mb-1" style="font-family: 'Lato', sans-serif;">Payne</h3>
          <p class="text-secondary text-xs">Stillwater</p>
        </a>
        <a href="/pawnee-county-bail-bonds" class="reveal reveal-delay-2 group text-center p-6 rounded-xl bg-white border border-transparent hover:border-gold/30 transition-all" style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">
          <p class="text-3xl mb-2">🏛️</p>
          <h3 class="text-agate text-base font-bold mb-1" style="font-family: 'Lato', sans-serif;">Pawnee</h3>
          <p class="text-secondary text-xs">Pawnee</p>
        </a>
        <a href="/lincoln-county-bail-bonds" class="reveal reveal-delay-3 group text-center p-6 rounded-xl bg-white border border-transparent hover:border-gold/30 transition-all" style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">
          <p class="text-3xl mb-2">🏛️</p>
          <h3 class="text-agate text-base font-bold mb-1" style="font-family: 'Lato', sans-serif;">Lincoln</h3>
          <p class="text-secondary text-xs">Chandler</p>
        </a>
        <a href="/kay-county-bail-bonds" class="reveal reveal-delay-4 group text-center p-6 rounded-xl bg-white border border-transparent hover:border-gold/30 transition-all" style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">
          <p class="text-3xl mb-2">🏛️</p>
          <h3 class="text-agate text-base font-bold mb-1" style="font-family: 'Lato', sans-serif;">Kay</h3>
          <p class="text-secondary text-xs">Ponca City</p>
        </a>
        <a href="/noble-county-bail-bonds" class="reveal reveal-delay-5 group text-center p-6 rounded-xl bg-white border border-transparent hover:border-gold/30 transition-all col-span-2 sm:col-span-1" style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">
          <p class="text-3xl mb-2">🏛️</p>
          <h3 class="text-agate text-base font-bold mb-1" style="font-family: 'Lato', sans-serif;">Noble</h3>
          <p class="text-secondary text-xs">Perry</p>
        </a>
      </div>

      <div class="reveal rounded-2xl p-8 md:p-10 text-center" style="background: linear-gradient(135deg, var(--agate-light) 0%, #d4e8e8 100%); border: 1px solid rgba(26,107,106,0.12);">
        <h3 class="text-agate text-xl mb-3">Payne County Jail Specialist</h3>
        <p class="text-secondary max-w-lg mx-auto mb-5">
          We specialize in Payne County Jail bonds with expedited processing and deep local knowledge of the courthouse system.
        </p>
        <a href="/payne-county-jail-bail-bonds" class="btn-outline text-sm">Learn More About Payne County →</a>
      </div>
    </div>
  </section>

  <!-- ═══ WHY CHOOSE US ═══ -->
  <section class="section-padding bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Why Us</span>
        <h2 class="text-agate mb-4">Why Choose Angel Bail Bonds?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 flex gap-4">
          <div class="icon-box icon-box-gold">🕐</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">24/7 Availability</h3>
            <p class="text-secondary text-sm leading-relaxed">Always ready to help in emergency situations, day or night, weekends and holidays.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-2 flex gap-4">
          <div class="icon-box icon-box-gold">⭐</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">5.0 Star Rating</h3>
            <p class="text-secondary text-sm leading-relaxed">27+ verified Google reviews showcasing our commitment to excellence and client care.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-3 flex gap-4">
          <div class="icon-box icon-box-gold">🏆</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">15+ Years Experience</h3>
            <p class="text-secondary text-sm leading-relaxed">Karri McBride brings deep expertise and courthouse relationships across Central Oklahoma.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-1 flex gap-4">
          <div class="icon-box icon-box-gold">👩‍💼</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">Women-Owned Business</h3>
            <p class="text-secondary text-sm leading-relaxed">A compassionate, detail-oriented approach to every case we handle.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-2 flex gap-4">
          <div class="icon-box icon-box-gold">🔒</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">Discretion & Confidentiality</h3>
            <p class="text-secondary text-sm leading-relaxed">Your privacy is our priority. All matters handled with utmost professionalism.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-3 flex gap-4">
          <div class="icon-box icon-box-gold">💳</div>
          <div>
            <h3 class="text-charcoal text-base font-bold mb-1.5" style="font-family: 'Lato', sans-serif;">Flexible Payment Plans</h3>
            <p class="text-secondary text-sm leading-relaxed">We work with you to find affordable solutions during difficult times.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="section-padding bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Testimonials</span>
        <h2 class="text-agate mb-4">What Our Clients Say</h2>
        <p class="text-secondary">5.0 Star Rating • 27+ Google Reviews</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="testimonial-card reveal reveal-delay-1">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-gold text-sm">★ ★ ★ ★ ★</span>
          </div>
          <p class="text-charcoal text-sm leading-relaxed mb-5 italic">
            "Karri was incredibly helpful during a stressful time. She made the process simple and treated us with compassion. Highly recommend Angel Bail Bonds!"
          </p>
          <div class="flex items-center gap-3">
            <div class="testimonial-avatar bg-agate text-cream text-xs">JM</div>
            <div>
              <p class="text-charcoal font-semibold text-sm">J. Martinez</p>
              <p class="text-secondary text-xs">Stillwater, OK</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-2">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-gold text-sm">★ ★ ★ ★ ★</span>
          </div>
          <p class="text-charcoal text-sm leading-relaxed mb-5 italic">
            "Excellent service and support. Available whenever I needed them. Best bail bond company in Stillwater. Thank you, Angel Bail Bonds!"
          </p>
          <div class="flex items-center gap-3">
            <div class="testimonial-avatar text-cream text-xs" style="background: #c9a84c;">MT</div>
            <div>
              <p class="text-charcoal font-semibold text-sm">M. Thompson</p>
              <p class="text-secondary text-xs">Payne County, OK</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-3">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-gold text-sm">★ ★ ★ ★ ★</span>
          </div>
          <p class="text-charcoal text-sm leading-relaxed mb-5 italic">
            "Professional, caring, and quick. Karri really went above and beyond to help us during a difficult situation. Grateful for her service."
          </p>
          <div class="flex items-center gap-3">
            <div class="testimonial-avatar bg-agate text-cream text-xs">RJ</div>
            <div>
              <p class="text-charcoal font-semibold text-sm">R. Johnson</p>
              <p class="text-secondary text-xs">Central Oklahoma</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="section-padding relative overflow-hidden" style="background: linear-gradient(160deg, #0f4a4a 0%, #1a6b6a 50%, #1d7574 100%);">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 80%, rgba(201,168,76,0.06) 0%, transparent 60%);"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <div class="reveal">
        <span class="section-label" style="color: rgba(201,168,76,0.8);">Get Help Now</span>
        <h2 class="text-cream mb-5" style="font-size: clamp(1.8rem, 3.5vw, 2.75rem);">Need Help Right Now?</h2>
        <p class="text-cream/70 text-lg mb-10 max-w-lg mx-auto">
          Don't wait. Contact Angel Bail Bonds immediately for 24/7 emergency bail bond services across Central Oklahoma.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+14056143000" class="btn-primary text-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (405) 614-3000
          </a>
          <a href="/contact" class="btn-secondary text-base">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
