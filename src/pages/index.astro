  <section class="section-padding" style="background: white;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Why Us</span>
        <h2 style="color: var(--slate-900); margin-bottom: 1rem;">Why Choose Angel Bail Bonds?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 flex gap-4">
          <div class="icon-box icon-box-gold">🕐</div>
          <div>
            <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.375rem;">24/7 Availability</h3>
            <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6;">Always ready to help in emergency situations, day or night, weekends and holidays.</p>
          </div>
        </div>

        <div class="reveal reveal-delay-2 flex gap-4">
          <div class="icon-box icon-box-gold">⭐</div>
          <div>
            <h3 style="color: var(--slate-900); font-size: 1rem; font-weight: 700; margin-bottom: 0.375rem;">5.0 Star Rating</h3>
