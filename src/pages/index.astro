---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Angel Bail Bonds',
  description: 'Professional bail bond services in Stillwater, Oklahoma. 15+ years of experience serving Central Oklahoma counties.',
  image: '/images/logo.webp',
  telephone: '(405) 614-3000',
  email: 'bailbondangel@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Stillwater',
    addressRegion: 'OK',
    addressCountry: 'US',
  },
  priceRange: '$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '27',
  },
  areaServed: [
    'Payne County',
    'Pawnee County',
    'Lincoln County',
    'Kay County',
    'Noble County',
  ],
};
---

<BaseLayout
  title="Bail Bonds in Stillwater, Oklahoma | Angel Bail Bonds 24/7"
  description="Angel Bail Bonds offers 24/7 professional bail bond services in Stillwater and Central Oklahoma. 15+ years experience, 5.0 stars, women-owned. Emergency bail bonds for Payne, Pawnee, Lincoln, Kay & Noble counties."
  structuredData={structuredData}
>
  <!-- ═══ HERO ═══ -->
  <section style="background: var(--slate-50); min-height: 88vh; display: flex; align-items: center; padding-top: 80px;">
    <div class="max-w-6xl mx-auto px-5 sm:px-6 w-full" style="padding-top: 40px; padding-bottom: 60px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <!-- Badge -->
          <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6" style="background: rgba(37,99,235,0.08); border: 1px solid rgba(37,99,235,0.15);">
            <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--green); display: inline-block;"></span>
            <span style="color: var(--blue); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Available 24/7 — Call Anytime</span>
          </div>

          <!-- Headline -->
          <h1 class="reveal" style="color: var(--slate-900); margin-bottom: 1.25rem;">
            Bail Bonds in <span style="color: var(--blue);">Stillwater</span> & Central Oklahoma
          </h1>

          <!-- Subheadline -->
          <p class="reveal" style="color: var(--slate-500); font-size: 1.15rem; line-height: 1.7; margin-bottom: 2rem; max-width: 520px;">
            Fast, confidential, and compassionate bail bond services. Trusted by families across 5 Oklahoma counties for over 15 years.
          </p>

          <!-- CTAs -->
          <div class="reveal flex flex-col sm:flex-row gap-4" style="margin-bottom: 2.5rem;">
            <a href="tel:+14056143000" class="btn-primary" style="font-size: 1.05rem;">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call Now: (405) 614-3000
            </a>
            <a href="/how-bail-works" class="btn-outline">
              Learn How Bail Works
            </a>
          </div>
        </div>

        <!-- Stats Panel -->
        <div class="reveal" style="background: white; border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-lg); border: 1px solid var(--slate-200);">
          <div class="grid grid-cols-2 gap-8">
            <div style="text-align: center;">
              <p class="stat-number" style="color: var(--navy);">24/7</p>
              <p class="stat-label">Always Available</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: var(--navy);">5.0<span style="font-size: 1.25rem; margin-left: 4px; color: var(--amber);">★</span></p>
              <p class="stat-label">Google Rating</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: var(--navy);">15+</p>
              <p class="stat-label">Years Experience</p>
            </div>
            <div style="text-align: center;">
              <p class="stat-number" style="color: var(--navy);">5</p>
              <p class="stat-label">Counties Served</p>
            </div>
          </div>
          <div style="margin-top: 1.75rem; padding-top: 1.75rem; border-top: 1px solid var(--slate-200); text-align: center;">
            <p style="color: var(--slate-500); font-size: 0.9rem;">Women-owned &bull; Licensed &bull; Insured</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section id="services" class="section-padding" style="background: white;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <span class="section-label">What We Do</span>
        <h2 style="color: var(--slate-900); margin-bottom: 1rem;">Bail Bond Services</h2>
        <p style="color: var(--slate-500); font-size: 1.1rem; max-width: 540px; margin: 0 auto;">
          We handle all types of bail situations with discretion, speed, and professionalism.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card reveal reveal-delay-1">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">⚖️</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Felony Bail Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Experienced handling of serious charges requiring substantial bail amounts.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">📋</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Misdemeanor Bail Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Quick processing for less serious charges with flexible payment options.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">🚗</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">DUI/DWI Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Specialized experience with impaired driving charges across Oklahoma counties.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-1">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">🛡️</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Domestic Violence Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Confidential handling of sensitive family matters with protective conditions.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">💊</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Drug Charges Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Expert assistance with possession and trafficking charges.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="icon-box icon-box-gold" style="margin-bottom: 1rem;">📄</div>
          <h3 style="color: var(--slate-900); font-size: 1.1rem; margin-bottom: 0.5rem;">Traffic & Warrant Bonds</h3>
          <p style="color: var(--slate-500); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem;">Fast resolution for traffic violations and outstanding warrant issues.</p>
          <p style="color: var(--blue); font-weight: 700; font-size: 0.85rem;">10% Premium</p>
        </div>
      </div>

      <div class="text-center reveal" style="margin-top: 3rem;">
        <a href="/services" class="btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICE AREAS ═══ -->
  <section class="section-padding" style="background: var(--slate-50);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
